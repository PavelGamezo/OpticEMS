<UserControl x:Class="OpticEMS.MVVM.View.Recipe.DetectionParametersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Recipe"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border CornerRadius="5"
            Padding="15,10,15,0">

        <Grid>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Detection Parameters" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <Grid Grid.Row="1">
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" 
                            Grid.Column="0" 
                            Margin="0,0,10,15">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Exposure Time" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Exposure Time (ms)" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="The amount of time the spectrometer sensor collects light for a single scan. Higher values increase signal but slow down the sampling rate." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>
                    </StackPanel>

                    <TextBox Text="{Binding SelectedRecipe.ExposureMs}" 
                             Background="#3E3E40"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="8"
                             Margin="0,5,0,0"/>

                    <TextBlock Text="ms" 
                               FontSize="10" 
                               Foreground="#999999"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0" 
                            Grid.Column="1" 
                            Margin="0,0,0,15">

                    <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center">

                        <TextBlock Text="Scans Numbers" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Scans to Average (ScansNum)" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="The number of individual spectra to be acquired and averaged by the device hardware before sending the data to the application." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="• Higher values: Significantly reduces signal noise (better SNR) but increases the total cycle time." 
                                                   Foreground="#AAAAAA" 
                                                   FontSize="10" 
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,3"/>

                                        <TextBlock Text="• Lower values: Provides faster updates for high-speed process monitoring." 
                                                   Foreground="#AAAAAA" 
                                                   FontSize="10" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>
                    </StackPanel>

                    <TextBox Text="{Binding SelectedRecipe.ScansNum}" 
                             Background="#3E3E40"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="8"
                             Margin="0,5,0,0"/>

                    <TextBlock Text="ms" 
                               FontSize="10" 
                               Foreground="#999999"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" 
                            Grid.Column="0" 
                            Margin="0,0,10,15">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Windows IN" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Window In Count" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="Number of consecutive stable measurements required to enter the detection window." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>

                    </StackPanel>

                    <TextBox Text="{Binding SelectedRecipe.WindowInCount}" 
                             Background="#3E3E40"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="8"
                             Margin="0,5,0,0"/>

                </StackPanel>

                <StackPanel Grid.Row="1" 
                            Grid.Column="1">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Windows OUT" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Window Out Count" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="Number of consecutive positive readings required to confirm that the Endpoint has actually been reached (prevents false triggers)." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>
                    </StackPanel>

                    <TextBox Text="{Binding SelectedRecipe.WindowOutCount}" 
                             Background="#3E3E40"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="8"
                             Margin="0,5,0,0"/>

                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
