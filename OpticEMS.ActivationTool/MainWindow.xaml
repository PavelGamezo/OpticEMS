<Window x:Class="OpticEMS.ActivationTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpticEMS.ActivationTool"
        xmlns:vm="clr-namespace:OpticEMS.ActivationTool.MVVM.ViewModels"
        xmlns:p="clr-namespace:OpticEMS.ActivationTool.MVVM.Views"
        mc:Ignorable="d"
        Title="OpticEMS - Activation Tool v1.0" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1C2833"
        AllowsTransparency="True" 
        WindowStyle="None"
        FontFamily="Segoe UI Semibold">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ActivationSettingsViewModel}">
            <p:ActivationSettings/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LicenseKeyContainerViewModel}">
            <p:LicenseKeyContainer/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="#1a1a1a" Height="40" MouseDown="Header_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="15,0">
                        <Grid Width="18" Height="18" VerticalAlignment="Center">
                            <Ellipse>
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF00B2FF" Offset="0.0"/>
                                        <GradientStop Color="#FF007ACC" Offset="0.5"/>
                                        <GradientStop Color="#FF003A66" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="8" Height="8" Stroke="#1a1a1a" StrokeThickness="4"/>
                        </Grid>
                        <TextBlock Text="Optic EMS | Activation Tool" Margin="10,0" FontSize="16" Foreground="#E8E9E8" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right" Width="40" Background="Transparent" BorderThickness="0" Click="Close_Click">
                        <TextBlock Text="✕" Foreground="#BDBDBD" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <ToggleButton Content="License Generator" Style="{StaticResource TabButtonStyle}" IsChecked="True" IsHitTestVisible="False"/>
                </StackPanel>

                <UserControl Grid.Row="1" Content="{Binding SettingsViewModel}"/>

                <Separator Grid.Row="2" Background="Gray" Margin="0"/>
                
                <UserControl Grid.Row="3" Content="{Binding LicenseContainerViewModel}"/>

            </Grid>
        </DockPanel>
    </Grid>
</Window>