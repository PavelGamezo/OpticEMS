<Window x:Class="OpticEMS.MVVM.View.Windows.RenameMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpticEMS.MVVM.View.Windows"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent"
        Opacity="0"
        ResizeMode="NoResize"
        Title="RenameMessageBox" Height="180" Width="350">

    <Window.Resources>
        <Storyboard x:Key="WindowOpeningAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:0.3"/>

            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.8" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.8" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowOpeningAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#252526" 
            CornerRadius="8" 
            BorderBrush="#3E3E40" 
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Border.RenderTransform>
            <ScaleTransform CenterX="165" CenterY="80"/>
        </Border.RenderTransform>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0">

                <TextBlock Text="Recipe Name" 
                           FontSize="11" 
                           Foreground="#999999"/>

                <TextBox Text="{Binding NewName}" 
                         Background="#3E3E40"
                         BorderThickness="0"
                         Foreground="White"
                         Padding="8"
                         Margin="0,5,5,0"/>
                
            </StackPanel>

            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,15,0,0">

                <Button Content="Yes" 
                        Width="80" 
                        Height="30" 
                        IsDefault="True" 
                        Click="Yes_Click" 
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#1a1a1a"
                        Foreground="White"/>

                <Button Content="No" 
                        Width="80" 
                        Height="30" 
                        IsDefault="True" 
                        Click="No_Click" 
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#1a1a1a"
                        Foreground="White"/>
                
            </StackPanel>
        </Grid>
    </Border>
</Window>
