<UserControl x:Class="OpticEMS.MVVM.View.SpectrumScan.SpectrumScan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.SpectrumScan"
             xmlns:converters="clr-namespace:OpticEMS.Common.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>

        <Style x:Key="ModeToggleStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="16,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="Fill" Value="#5A5A5A"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ Панель управления ============ -->
        <Border Grid.Row="0"
                Background="#252525"
                Padding="5">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Content="Run"
                            Style="{StaticResource ActionButtonStyle}"
                            Height="32"
                            Background="#222120"
                            Width="80"
                            Command="{Binding StartScanCommand}"
                            Padding="0"
                            Margin="0,0,8,0"/>

                    <Button Content="Stop"
                            Style="{StaticResource ActionButtonStyle}"
                            Height="32"
                            Width="80"
                            Background="#222120"
                            Command="{Binding StopScanCommand}"
                            Padding="0"
                            Margin="0,0,8,0"/>

                    <Button Content="Reset Baseline"
                            Style="{StaticResource ActionButtonStyle}"
                            Height="32"
                            Width="100"
                            Background="#222120"
                            Command="{Binding ResetBaselineCommand}"
                            Padding="0"
                            Margin="0,0,8,0"/>
                    
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <RadioButton Content="Current"
                                 GroupName="ChartMode"
                                 Style="{StaticResource ModeToggleStyle}"
                                 IsChecked="{Binding ChartViewModel.Mode, 
                                            Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Current}"
                                 Margin="0,0,4,0"/>

                    <RadioButton Content="Diff"
                                 GroupName="ChartMode"
                                 Style="{StaticResource ModeToggleStyle}"
                                 IsChecked="{Binding ChartViewModel.Mode, 
                                            Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Diff}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#252525"
                Padding="10"
                Margin="0,0,0,5">

            <StackPanel Orientation="Horizontal">

                <Ellipse VerticalAlignment="Center"
                          Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Fill" Value="#2ECC71"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock VerticalAlignment="Center"
                           Foreground="#BDBDBD"
                           Margin="0,0,24,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Idle"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Text" Value="Scanning"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock VerticalAlignment="Center"
                           Foreground="#9AA5AE">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Baseline not captured"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasBaseline}" Value="True">
                                    <Setter Property="Text" Value="Baseline captured"/>
                                    <Setter Property="Foreground" Value="#7FB3D5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#252525">
            <ContentControl Grid.Row="1" Content="{Binding ChartViewModel}" />
        </Border>

    </Grid>
</UserControl>
