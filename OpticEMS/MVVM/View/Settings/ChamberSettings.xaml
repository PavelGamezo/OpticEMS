<UserControl x:Class="OpticEMS.MVVM.View.Settings.ChamberSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Settings"
             xmlns:converters="clr-namespace:OpticEMS.Common.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent"
             FontFamily="{materialDesign:MaterialDesignFont}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Chamber Configuration" 
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontWeight="Light"
                   FontSize="26"
                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                   Foreground="#888888"
                   Margin="24"/>

        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Center">

            <StackPanel Margin="24,16,24,20">

                <ItemsControl ItemsSource="{Binding ChannelSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="520" 
                                    Margin="0,0,0,12" 
                                    Padding="20"
                                    Background="#292929"
                                    BorderBrush="#3E3E40"
                                    CornerRadius="5"
                                    HorizontalAlignment="Left">

                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.6" Color="#000000"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Vertical">

                                        <!-- Chamber ID -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="{Binding ChannelId, StringFormat='Chamber ID: {0}'}" 
                                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                       Foreground="White" 
                                                       FontWeight="SemiBold" 
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding AvailableSpectrometers}"
                                                      SelectedItem="{Binding SelectedSpectrometer}"
                                                      Style="{StaticResource MaterialDesignComboBox}"
                                                      materialDesign:HintAssist.Hint="Select Spectrometer"
                                                      materialDesign:TextFieldAssist.TextBoxViewMargin="1,0"
                                                      Foreground="White"
                                                      Height="36"
                                                      Margin="0,0,8,0"/>

                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.SpectrometerTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding SelectedSpectrometerType}"
                                                      materialDesign:HintAssist.Hint="Type"
                                                      Foreground="White"
                                                      Height="36"/>
                                        </Grid>

                                        <Border Visibility="{Binding IsYixistIpVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Background="#1E1E1E"
                                                CornerRadius="4"
                                                Padding="12,10"
                                                Margin="0,0,0,12">
                                            <StackPanel>

                                                <TextBlock Text="Yixist IP Address"
                                                           FontSize="11"
                                                           Foreground="#888888"
                                                           Margin="0,0,0,6"/>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding DeviceIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                             materialDesign:HintAssist.Hint="192.168.0.101"
                                                             Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                             Foreground="White"
                                                             Height="36"
                                                             Margin="0,0,8,0"
                                                             VerticalContentAlignment="Center">
                                                        <TextBox.InputBindings>
                                                            <KeyBinding Key="Return"
                                                                        Command="{Binding DataContext.ConnectYixistByIpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                        </TextBox.InputBindings>
                                                    </TextBox>

                                                    <Button Grid.Column="1"
                                                            Command="{Binding DataContext.ConnectYixistByIpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                                            Background="#2D4A43"
                                                            Foreground="White"
                                                            Height="36"
                                                            Padding="12,0"
                                                            ToolTip="Connect and read serial number">
                                                        <Grid>
                                                            <ProgressBar IsIndeterminate="True"
                                                                         Width="16" Height="16"
                                                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                                         Visibility="{Binding IsYixistConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            <materialDesign:PackIcon Kind="LanConnect"
                                                                                     Width="16" Height="16"
                                                                                     VerticalAlignment="Center">
                                                                <materialDesign:PackIcon.Visibility>
                                                                    <Binding Path="IsYixistConnecting" Converter="{StaticResource InverseBooleanToVisibilityConverter}"/>
                                                                </materialDesign:PackIcon.Visibility>
                                                            </materialDesign:PackIcon>
                                                        </Grid>
                                                    </Button>
                                                </Grid>

                                            </StackPanel>
                                        </Border>

                                        <Border Height="1" Background="#2D2D30" Margin="0,4,0,8"/>

                                        <!-- Calibration coefficients -->
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="Calibration coefficients" 
                                                       FontSize="14"
                                                       Foreground="LightGray"
                                                       FontWeight="Bold"
                                                       Margin="5,10,5,20"/>
                                            <DockPanel>
                                                <TextBox Width="220" Height="36" Margin="0,0,0,5"
                                                         Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                         Text="{Binding CoefficientA, StringFormat={}{0:G6}}"
                                                         materialDesign:HintAssist.Hint="Coefficient A"/>
                                                <TextBox Width="220" Height="36" Margin="0,0,0,5"
                                                         Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                         Text="{Binding CoefficientB, StringFormat={}{0:G6}}"
                                                         materialDesign:HintAssist.Hint="Coefficient B"/>
                                            </DockPanel>
                                            <DockPanel>
                                                <TextBox Width="220" Height="36"
                                                         Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                         Text="{Binding CoefficientC, StringFormat={}{0:G6}}"
                                                         materialDesign:HintAssist.Hint="Coefficient C"/>
                                                <TextBox Width="220" Height="36"
                                                         Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                         Text="{Binding CoefficientD, StringFormat={}{0:G6}}"
                                                         materialDesign:HintAssist.Hint="Coefficient D"/>
                                            </DockPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="#2D2D30" Margin="0,4,0,8"/>

                                        <!-- Trim -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4">
                                            <TextBox Text="{Binding TrimLeft, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="Left trim [nm]"
                                                     Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                     Width="210" Height="36"
                                                     Foreground="White"
                                                     HorizontalContentAlignment="Center"/>
                                            <TextBlock Text="—" Foreground="#555555" FontSize="14"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                            <TextBox Text="{Binding TrimRight, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="Right trim [nm]"
                                                     Background="{StaticResource MaterialDesignDarkSeparatorBackground}"
                                                     Width="210" Height="36"
                                                     Foreground="White"
                                                     HorizontalContentAlignment="Center"/>
                                        </StackPanel>

                                    </StackPanel>

                                    <!-- Delete button -->
                                    <Button Grid.Column="1"
                                            Command="{Binding DataContext.RemoveChamberCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignToolButton}"
                                            Foreground="#995555"
                                            Width="28" Height="28"
                                            Padding="0"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Right"
                                            ToolTip="Remove configuration">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Bottom buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,24">
                    <Button Command="{Binding AddChamberCommand}" 
                            Style="{StaticResource ActionButtonStyle}"
                            materialDesign:ButtonAssist.CornerRadius="2"
                            Width="150" Height="36" 
                            BorderBrush="#555555"
                            Foreground="#CCCCCC"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="ADD CHAMBER" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SaveSettingsCommand}" 
                            Style="{StaticResource ActionButtonStyle}"
                            materialDesign:ButtonAssist.CornerRadius="2"
                            Background="#2D4A43"
                            Foreground="#E0F2F1"
                            Width="150" Height="36">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSaveOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="SAVE SETTINGS" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>