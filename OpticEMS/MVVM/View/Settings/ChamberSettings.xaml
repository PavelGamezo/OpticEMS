<Page x:Class="OpticEMS.MVVM.View.Settings.ChamberSettings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OpticEMS.MVVM.View.Settings"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChamberSettings">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Grid.Row="1">

            <StackPanel Margin="20">
                <ItemsControl ItemsSource="{Binding ChannelSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#3E3E40" 
                                    BorderThickness="1" 
                                    CornerRadius="10" 
                                    Padding="20" 
                                    Margin="0,0,0,20" 
                                    Background="#1E1E1E"
                                    Width="500">
                                
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                                      Direction="315" 
                                                      ShadowDepth="4" 
                                                      Opacity="0.6" 
                                                      BlurRadius="12"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">

                                        <TextBlock Text="Select Spectrometer Device:" 
                                                   Foreground="#AAAAAA" 
                                                   FontSize="12"
                                                   Margin="0,0,0,8"/>

                                        <ComboBox ItemsSource="{Binding AvailableSpectrometers}" 
                                                  SelectedItem="{Binding SelectedSpectrometer}" 
                                                  Style="{StaticResource ComboBoxStyle}"
                                                  Height="35"
                                                  Width="300"
                                                  HorizontalAlignment="Left"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding DataContext.RemoveChamberCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Top"
                                            Cursor="Hand"
                                            ToolTip="Delete this chamber">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="15" 
                                                                    Width="30" Height="30">
                                                                <TextBlock Text="✕" 
                                                                           Foreground="#E74C3C" 
                                                                           FontSize="16" 
                                                                           HorizontalAlignment="Center" 
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2DE74C3C"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel HorizontalAlignment="Center"
                            Orientation="Horizontal">

                    <Button Content="Add chamber" 
                            Command="{Binding AddChamberCommand}" 
                            Style="{StaticResource ActionButtonStyle}"
                            Width="150" 
                            Height="40" 
                            Margin="0 20 10 0"
                            Foreground="White"
                            Background="#222120"
                            FontWeight="Bold"/>

                    <Button Content="Save settings" 
                            Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            Width="150" 
                            Height="40" 
                            Margin="0 20 0 0" 
                            Foreground="White"
                            Background="DarkSlateGray"
                            FontWeight="Bold"/>
                    
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
