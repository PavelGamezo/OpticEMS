<UserControl x:Class="OpticEMS.MVVM.View.Recipe.OveretchingParametersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Recipe"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <Border CornerRadius="5"
            Padding="15,15,15,0">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Over Etching Parameters" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Margin="0,0,10,0">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Over Etch Enabled" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Enable Over-etch Phase" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="Enables the over-etch phase after endpoint detection." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>

                    </StackPanel>

                    <ComboBox Background="#3E3E40"
                              BorderThickness="0"
                              Foreground="White"
                              Padding="8"
                              Margin="0,5,0,0"
                              ItemsSource="{Binding YesNoOptions}"
                              SelectedItem="{Binding SelectedOverEtchText}"
                              Style="{StaticResource ComboBoxStyle}"
                              Height="32"/>
                </StackPanel>

                <StackPanel Grid.Column="1">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Over Etch Value" 
                               FontSize="11" 
                               Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Over-etch Duration (ms)" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="Duration of the over-etch phase in seconds after endpoint has been detected." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>

                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>

                    </StackPanel>
                    <Grid Margin="0,5,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 Text="{Binding SelectedRecipe.OverEtchValue}" 
                                 Background="#3E3E40"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Padding="8"/>

                        <Border Grid.Column="1" 
                                Background="#3E3E40"
                                CornerRadius="0,3,3,0"
                                Padding="8,8">

                            <TextBlock Text="ms" 
                                       Foreground="White"/>

                        </Border>

                    </Grid>

                </StackPanel>
            </Grid>

        </Grid>

    </Border>

</UserControl>
