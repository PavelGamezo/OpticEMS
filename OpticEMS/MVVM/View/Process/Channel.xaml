<UserControl x:Class="OpticEMS.MVVM.View.Process.Channel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Process"
             xmlns:converters="clr-namespace:OpticEMS.Common.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Grid.Column="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#1f1f1f"
              Margin="0,0,0,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal">

                <Button Command="{Binding StartProcessCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Width="70">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Grid Width="10" Height="10" Margin="0,0,10,0">
                            <Path Data="M3,3 L13,8 L3,13 Z" 
                                  Fill="White" 
                                  Stretch="Uniform"/>
                        </Grid>
                        <TextBlock Text="Start" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding StopProcessCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,0"
                        Width="30">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="5" Canvas.Top="4" Width="4" Height="16" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Canvas.Left="15" Canvas.Top="4" Width="4" Height="16" Fill="White" RadiusX="1" RadiusY="1"/>
                            </Canvas>
                        </Viewbox>
                    </StackPanel>

                </Button>

                <Button Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Width="40"
                        Command="{Binding ExportDataCommand}">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">

                                <Path Data="M12,4 L12,16 M8,12 L12,16 L16,12"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"/>
                                <Path Data="M4,20 L20,20"
                                      Stroke="White"
                                      StrokeThickness="2"/>

                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Button>

                <Button Command="{Binding StartReprocessCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Width="100">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Grid Width="10" Height="10" Margin="0,0,10,0">
                            <Path Data="M12 4V1L8 5L12 9V6C15.31 6 18 8.69 18 12C18 15.31 15.31 18 12 18C8.69 18 6 15.31 6 12H4C4 16.42 7.58 20 12 20C16.42 20 20 16.42 20 12C20 7.58 16.42 4 12 4Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                  Stretch="Uniform"/>
                        </Grid>
                        <TextBlock Text="Reprocess" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <ContentControl Grid.Row="1" 
                            Content="{Binding ProcessChartViewModel}"
                            Visibility="{Binding IsNoiseFloorMode,
                                        Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

            <ContentControl Grid.Row="1" 
                            Content="{Binding SpectrumScanChartViewModel}"
                            Visibility="{Binding IsNoiseFloorMode,
                                        Converter={StaticResource BooleanToVisibilityConverter}}"/>

        </Grid>

        <GridSplitter Grid.Row="1" 
                      Height="6" 
                      VerticalAlignment="Center" 
                      HorizontalAlignment="Stretch" 
                      Background="#2d2d30"
                      ResizeBehavior="PreviousAndNext"/>

        <Grid Grid.Row="2" Background="#1f1f1f">

            <Border Grid.Row="2" 
                    Background="#1f1f1f" 
                    CornerRadius="3" 
                    Padding="10"
                    Margin="0,0,0,0">

                <ContentControl Grid.Row="2" 
                    Content="{Binding SpectrumChartViewModel}" />

            </Border>
        </Grid>
    </Grid>
</UserControl>
