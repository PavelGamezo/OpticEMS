<UserControl x:Class="OpticEMS.MVVM.View.Recipe.DetectionParametersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Recipe"
             mc:Ignorable="d" d:DesignWidth="800">

    <Border CornerRadius="5"
            Padding="15,15,15,0">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Detection Parameters" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,5"/>

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" 
                            Grid.Column="0" 
                            Margin="0,0,10,0">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Windows IN" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Window In Count" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="The number of consecutive detection windows that must show the signal inside the detection band to confirm endpoint detection (stability after the drop)." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>

                    </StackPanel>

                    <TextBox Text="{Binding SelectedRecipe.WindowInCount}" 
                             Background="#3E3E40"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="8"
                             Margin="0,5,0,0"/>

                </StackPanel>

                <StackPanel Grid.Row="1" 
                            Grid.Column="1">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Windows OUT" 
                                   FontSize="11" 
                                   Foreground="#999999"/>

                        <Border Margin="6,0,0,0" 
                                Width="14" 
                                Height="14" 
                                CornerRadius="7" 
                                Background="#444444" 
                                Cursor="Help"
                                VerticalAlignment="Center"
                                ToolTipService.InitialShowDelay="100">

                            <TextBlock Text="?" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Foreground="#AAAAAA" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,1"/>

                            <Border.ToolTip>

                                <ToolTip Background="#252526" 
                                         Foreground="White" 
                                         BorderBrush="#454545"
                                         Padding="10"
                                         HasDropShadow="True">

                                    <StackPanel Width="200">

                                        <TextBlock Text="Window Out Count" 
                                                   FontWeight="Bold" 
                                                   Foreground="White" 
                                                   Margin="0,0,0,5"/>

                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                               Height="108"
                                               Width="192"
                                               Stretch="Uniform" 
                                               Margin="0,5"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                        <TextBlock Text="The number of consecutive detection windows that must show the signal outside the detection band to confirm the start of endpoint transition." 
                                                   Foreground="#CCCCCC" 
                                                   FontSize="11" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </ToolTip>

                            </Border.ToolTip>

                        </Border>
                    </StackPanel>

                    <TextBox Text="{Binding SelectedRecipe.WindowOutCount}" 
                             Background="#3E3E40"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="8"
                             Margin="0,5,0,0"/>

                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
