<UserControl x:Class="OpticEMS.ActivationTool.MVVM.Views.ActivationSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.ActivationTool.MVVM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="260" d:DesignWidth="800">
    
    <Border Background="#1a1a1a" Padding="30">
        <StackPanel>
            <TextBlock Text="CLIENT HARDWARE ID" 
                       Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>

            <TextBox Style="{StaticResource OpticTextBox}"
                     Text="{Binding Hwid, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" 
                     Margin="0,0,0,20"
                     Background="#141414"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="EXPIRATION DATE"
                               Foreground="White"
                               FontSize="10" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    
                    <Border Background="#141414" 
                            BorderBrush="Gray" 
                            BorderThickness="1" 
                            Padding="8">
                        
                        <DatePicker SelectedDate="{Binding ExpiryDate}" 
                                    BorderThickness="0" 
                                    Background="Transparent" 
                                    Foreground="White">
                            
                            <DatePicker.Resources>
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="LICENSED CHANNELS" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource OpticTextBox}"
                             Text="{Binding ChannelCount, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" 
                             Margin="0,0,0,20"
                             Background="#141414"/>
                </StackPanel>
            </Grid>
            
            <Button Content="GENERATE KEY" 
                    Command="{Binding GenerateSecretKeyCommand}"
                    Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Right"
                    Width="160"
                    Height="30"
                    Background="#141414"
                    Foreground="White"
                    Margin="0,0,0,0" />
            
        </StackPanel>
    </Border>
</UserControl>
