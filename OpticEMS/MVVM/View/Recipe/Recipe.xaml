<Page x:Class="OpticEMS.MVVM.View.Recipe.Recipe"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OpticEMS.MVVM.View.Recipe"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="Recipe">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#1a1a1a"
                Padding="25,5,5,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Process Recipes" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">

                    <Button Content="New recipe" 
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding NewRecipeCommand}"/>

                    <Button Content="Rename"
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RenameRecipeCommand}"/>

                    <Button Grid.Column="2" 
                            Content="Apply"
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ApplySelectedRecipeCommand}"/>

                    <Button Grid.Column="3" 
                            Content="Save" 
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding SaveRecipeCommand}"/>

                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="#252526"
                    Margin="5,0,5,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="#1f1f1f"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Recipe database"
                                       FontWeight="Bold"
                                      FontSize="12" 
                                      Foreground="White"
                                      Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Background="#3E3E40" 
                                        CornerRadius="3"
                                        Height="28">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="🔍" 
                                                   Margin="8,0"
                                                   Foreground="#999999"
                                                   VerticalAlignment="Center"/>

                                        <TextBox Grid.Column="1" 
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </Border>

                                <Button Grid.Column="1" 
                                        Content="📁" 
                                        Width="28" 
                                        Height="28"
                                        Margin="5,0,0,0"
                                        Background="#3E3E40"
                                        BorderThickness="0"
                                        Foreground="White"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ListView Grid.Row="2" 
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding RecipesView}"
                              SelectedItem="{Binding SelectedRecipe}"
                              Margin="0,5,0,0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="OuterBorder" 
                                                    Background="Transparent" 
                                                    BorderBrush="Transparent"
                                                    BorderThickness="3,0,0,0" 
                                                    Margin="2,1"
                                                    SnapsToDevicePixels="True">

                                                <ContentPresenter />

                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="OuterBorder" Property="Background" Value="#1AFFFFFF"/>
                                                    <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>

                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="OuterBorder" Property="Background" Value="#3d3d40"/>
                                                    <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,10,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="📄" 
                                               Foreground="White"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                                    <StackPanel Grid.Column="1" 
                                                VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>

                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}Created: {0:dd.MM.yyyy}'}" 
                                                   FontSize="10"
                                                   Foreground="#666666"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding LastModifiedAt, StringFormat='{}{0:HH:mm}'}" 
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="#999999"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Grid.Row="3" 
                            Background="#1f1f1f" 
                            CornerRadius="0,0,5,5"
                            Padding="10"
                            BorderBrush="#3E3E40"
                            BorderThickness="0,1,0,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal">

                                <TextBlock Text="All recipes: " 
                                           Foreground="#999999"/>

                                <TextBlock Text="{Binding RecipeCount}" 
                                           Foreground="#999999"/>

                            </StackPanel>

                            <StackPanel Grid.Column="1" 
                                       Orientation="Horizontal">

                                <Button Content="🗑️" 
                                        Command="{Binding DeleteRecipeCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Width="25" 
                                        Height="25"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#999999"/>

                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" 
                    Background="#1f1f1f">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                    </ScrollViewer.Resources>

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Background="#1f1f1f"
                                Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                    <TextBlock Grid.Column="0" 
                                           Text="{Binding SelectedRecipe.Name}" 
                                           FontSize="24" 
                                           FontWeight="Bold" 
                                           Foreground="White"/>

                                    <Border Margin="10,0,0,0" 
                                            Width="14" 
                                            Height="14" 
                                            CornerRadius="7" 
                                            Background="#444444" 
                                            Cursor="Help"
                                            VerticalAlignment="Center"
                                            ToolTipService.InitialShowDelay="100">

                                        <TextBlock Text="?" 
                                                   FontSize="10" 
                                                   FontWeight="Bold"
                                                   Foreground="#AAAAAA" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,1"/>

                                        <Border.ToolTip>

                                            <ToolTip Background="#252526" 
                                                     Foreground="White" 
                                                     BorderBrush="#454545"
                                                     Padding="10"
                                                     HasDropShadow="True">

                                                <StackPanel Width="200">

                                                    <TextBlock Text="Recipe Name" 
                                                               FontWeight="Bold" 
                                                               Foreground="White" 
                                                               Margin="0,0,0,5"/>

                                                    <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                           Height="108"
                                                           Width="192"
                                                           Stretch="Uniform" 
                                                           Margin="0,5"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                                    <TextBlock Text="Unique identifier for the current process configuration." 
                                                               Foreground="#CCCCCC" 
                                                               FontSize="11" 
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                            </ToolTip>

                                        </Border.ToolTip>

                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Padding="15">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" 
                                           Text="Chamber setup" 
                                           FontSize="12" 
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,5"/>

                                <Grid Grid.Row="1">
                                    
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Channel" 
                                                       FontSize="11" 
                                                       Foreground="#999999" 
                                                       VerticalAlignment="Center"/>

                                            <Border Margin="6,0,0,0" 
                                                    Width="14" 
                                                    Height="14" 
                                                    CornerRadius="7" 
                                                    Background="#444444" 
                                                    Cursor="Help"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.InitialShowDelay="100">

                                                <TextBlock Text="?" 
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           Foreground="#AAAAAA" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,1"/>

                                                <Border.ToolTip>

                                                    <ToolTip Background="#252526" 
                                                             Foreground="White" 
                                                             BorderBrush="#454545"
                                                             Padding="10"
                                                             HasDropShadow="True">

                                                        <StackPanel Width="200">
                                                            <TextBlock Text="Channel number" 
                                                                       FontWeight="Bold" 
                                                                       Foreground="White" 
                                                                       Margin="0,0,0,5"/>

                                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                   Height="108"
                                                                   Width="192"
                                                                   Stretch="Uniform" 
                                                                   Margin="0,5"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                                            <TextBlock Text="Ensure the number matches the controlled channel number." 
                                                                       Foreground="#CCCCCC" 
                                                                       FontSize="11" 
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                    </ToolTip>

                                                </Border.ToolTip>

                                            </Border>
                                        </StackPanel>

                                        <TextBox Text="{Binding SelectedRecipe.Channel, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#3E3E40"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 Padding="8"
                                                 Margin="0,5,5,0"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" 
                                Padding="15,0,15,15">

                            <StackPanel>

                                <Grid>

                                    <TextBlock Text="Wavelength monitoring" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="White"
                                               Margin="0,5,0,0"/>

                                    <Button Content="+ Add"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Foreground="White"
                                            Background="#272727"
                                            Command="{Binding AddWavelengthCommand}" 
                                            HorizontalAlignment="Right"/>

                                </Grid>

                                <ItemsControl ItemsSource="{Binding WavelengthItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Border BorderBrush="#3E3E40" 
                                                    BorderThickness="1"
                                                    Margin="0,15,5,0"
                                                    Padding="10" 
                                                    CornerRadius="4"
                                                    Background="#1E1E1E">

                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" 
                                                                      Direction="315" 
                                                                      ShadowDepth="4" 
                                                                      Opacity="0.6" 
                                                                      BlurRadius="12"/>
                                                </Border.Effect>

                                                <StackPanel>
                                                    
                                                    <Grid>

                                                        <StackPanel Orientation="Horizontal">
                                                            
                                                            <TextBlock Text="Wavelength" 
                                                                       FontSize="11" 
                                                                       Foreground="#999999"/>
                                                            
                                                            <Border Margin="6,0,0,0" 
                                                                    Width="14" 
                                                                    Height="14" 
                                                                    CornerRadius="7" 
                                                                    Background="#444444" 
                                                                    Cursor="Help"
                                                                    VerticalAlignment="Center"
                                                                    ToolTipService.InitialShowDelay="100">

                                                                <TextBlock Text="?" 
                                                                           FontSize="10" 
                                                                           FontWeight="Bold"
                                                                           Foreground="#AAAAAA" 
                                                                           HorizontalAlignment="Center" 
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,0,1"/>

                                                                <Border.ToolTip>

                                                                    <ToolTip Background="#252526" 
                                                                             Foreground="White" 
                                                                             BorderBrush="#454545"
                                                                             Padding="10"
                                                                             HasDropShadow="True">

                                                                        <StackPanel Width="200">
                                                                            <TextBlock Text="Target Wavelengths (nm)" 
                                                                                       FontWeight="Bold" 
                                                                                       Foreground="White" 
                                                                                       Margin="0,0,0,5"/>

                                                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                                   Height="108"
                                                                                   Width="192"
                                                                                   Stretch="Uniform" 
                                                                                   Margin="0,5"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                                                            <TextBlock Text="Specific spectral lines (in nanometers) monitored to track chemical species in the plasma." 
                                                                                       Foreground="#CCCCCC" 
                                                                                       FontSize="11" 
                                                                                       TextWrapping="Wrap"/>
                                                                        </StackPanel>

                                                                    </ToolTip>

                                                                </Border.ToolTip>

                                                            </Border>
                                                        </StackPanel>

                                                        <Button Content="✕" 
                                                                Style="{StaticResource ActionButtonStyle}"
                                                                Command="{Binding DataContext.RemoveWavelengthCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                Width="15" 
                                                                Height="15"
                                                                Margin="0"
                                                                HorizontalAlignment="Right" 
                                                                Background="Transparent"
                                                                Foreground="Gray"
                                                                BorderThickness="0"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>

                                                    <TextBox Text="{Binding Wavelength}" 
                                                             Background="#3E3E40" 
                                                             Foreground="White" 
                                                             BorderThickness="0" 
                                                             Padding="8" 
                                                             Margin="0,5"/>

                                                    <StackPanel Orientation="Horizontal">

                                                        <TextBlock Text="Color" 
                                                                   FontSize="11" 
                                                                   Foreground="#999999"/>
                                                        
                                                        <Border Margin="6,0,0,0" 
                                                                Width="14" 
                                                                Height="14" 
                                                                CornerRadius="7" 
                                                                Background="#444444" 
                                                                Cursor="Help"
                                                                VerticalAlignment="Center"
                                                                ToolTipService.InitialShowDelay="100">

                                                            <TextBlock Text="?" 
                                                                       FontSize="10" 
                                                                       FontWeight="Bold"
                                                                       Foreground="#AAAAAA" 
                                                                       HorizontalAlignment="Center" 
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,0,1"/>

                                                            <Border.ToolTip>

                                                                <ToolTip Background="#252526" 
                                                                         Foreground="White" 
                                                                         BorderBrush="#454545"
                                                                         Padding="10"
                                                                         HasDropShadow="True">

                                                                    <StackPanel Width="200">
                                                                        <TextBlock Text="Target colors" 
                                                                                   FontWeight="Bold" 
                                                                                   Foreground="White" 
                                                                                   Margin="0,0,0,5"/>

                                                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                               Height="108"
                                                                               Width="192"
                                                                               Stretch="Uniform" 
                                                                               Margin="0,5"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                                                        <TextBlock Text="Assigned colors for each wavelength to distinguish them on the real-time charts." 
                                                                                   Foreground="#CCCCCC" 
                                                                                   FontSize="11" 
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>

                                                                </ToolTip>

                                                            </Border.ToolTip>

                                                        </Border>
                                                    </StackPanel>

                                                    <xctk:ColorPicker SelectedColor="{Binding Color, UpdateSourceTrigger=PropertyChanged}" 
                                                                      Height="30" Margin="0,5,0,0"
                                                                      Style="{StaticResource DarkColorPicker}" 
                                                                      UsingAlphaChannel="False"/>

                                                    <StackPanel Orientation="Horizontal">
                                                        
                                                        <TextBlock Text="Detection window high"
                                                                   FontSize="11"
                                                                   Margin="0,10,0,0"
                                                                   Foreground="#999999"/>
                                                        
                                                        <Border Margin="6,10,0,0" 
                                                                Width="14" 
                                                                Height="14" 
                                                                CornerRadius="7" 
                                                                Background="#444444" 
                                                                Cursor="Help"
                                                                VerticalAlignment="Center"
                                                                ToolTipService.InitialShowDelay="100">

                                                            <TextBlock Text="?" 
                                                                       FontSize="10" 
                                                                       FontWeight="Bold"
                                                                       Foreground="#AAAAAA" 
                                                                       HorizontalAlignment="Center" 
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,0,1"/>

                                                            <Border.ToolTip>

                                                                <ToolTip Background="#252526" 
                                                                         Foreground="White" 
                                                                         BorderBrush="#454545"
                                                                         Padding="10"
                                                                         HasDropShadow="True">

                                                                    <StackPanel Width="200">
                                                                        <TextBlock Text="Detection window high" 
                                                                                   FontWeight="Bold" 
                                                                                   Foreground="White"/>

                                                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                               Height="108"
                                                                               Width="192"
                                                                               Stretch="Uniform" 
                                                                               Margin="0,5"
                                                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                                                        <TextBlock Text="Upper intensity limits used as triggers for state changes in the detection algorithm." 
                                                                                   Foreground="#CCCCCC" 
                                                                                   FontSize="11" 
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>

                                                                </ToolTip>

                                                            </Border.ToolTip>

                                                        </Border>

                                                    </StackPanel>
                                                    
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Grid.Column="0" 
                                                                 Text="{Binding SignalHigh, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="#3E3E40"
                                                                 BorderThickness="0"
                                                                 Foreground="White"
                                                                 Padding="8"
                                                                 Margin="0,5,0,0"/>

                                                        <Border Grid.Column="1" 
                                                                Background="#3E3E40"
                                                                CornerRadius="0,1,1,0"
                                                                Margin="0,5,0,0"
                                                                Padding="8,8,7,0">

                                                            <TextBlock Text="%" 
                                                                       Foreground="White"/>

                                                        </Border>

                                                    </Grid>

                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    
                                    <TextBlock Text="Autocalibration" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="White"
                                               Margin="0,15,0,5"/>

                                    <Border Margin="6,5,0,0" 
                                            Width="14" 
                                            Height="14" 
                                            CornerRadius="7" 
                                            Background="#444444" 
                                            Cursor="Help"
                                            VerticalAlignment="Center"
                                            ToolTipService.InitialShowDelay="100">

                                        <TextBlock Text="?" 
                                                   FontSize="10" 
                                                   FontWeight="Bold"
                                                   Foreground="#AAAAAA" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,1"/>

                                        <Border.ToolTip>

                                            <ToolTip Background="#252526" 
                                                     Foreground="White" 
                                                     BorderBrush="#454545"
                                                     Padding="10"
                                                     HasDropShadow="True">

                                                <StackPanel Width="200">
                                                    <TextBlock Text="Autocalibration" 
                                                               FontWeight="Bold" 
                                                               Foreground="White"/>

                                                    <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                           Height="108"
                                                           Width="192"
                                                           Stretch="Uniform" 
                                                           Margin="0,5"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                                    <TextBlock Text="Upper intensity limits used as triggers for state changes in the detection algorithm." 
                                                               Foreground="#CCCCCC" 
                                                               FontSize="11" 
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                            </ToolTip>

                                        </Border.ToolTip>

                                    </Border>

                                </StackPanel>

                                <ComboBox Background="#3E3E40"
                                          BorderThickness="0"
                                          Foreground="White"
                                          Padding="8"
                                          Margin="0,5,0,0"
                                          ItemsSource="{Binding YesNoOptions}"
                                          SelectedItem="{Binding SelectedAutocalibrationText}"
                                          Style="{StaticResource ComboBoxStyle}"
                                          Height="32"/>

                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Padding="15,10,15,0">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" 
                                           Text="Timing Parameters" 
                                           FontSize="12" 
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,5"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" 
                                                Grid.Column="0"
                                                Margin="0,0,10,5">

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                            <TextBlock Text="Initial Delay" 
                                                   FontSize="11" 
                                                   Foreground="#999999"/>

                                            <Border Margin="6,0,0,0" 
                                                    Width="14" 
                                                    Height="14" 
                                                    CornerRadius="7" 
                                                    Background="#444444" 
                                                    Cursor="Help"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.InitialShowDelay="100">

                                                <TextBlock Text="?" 
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           Foreground="#AAAAAA" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,1"/>

                                                <Border.ToolTip>

                                                    <ToolTip Background="#252526" 
                                                             Foreground="White" 
                                                             BorderBrush="#454545"
                                                             Padding="10"
                                                             HasDropShadow="True">

                                                        <StackPanel Width="200">
                                                            
                                                            <TextBlock Text="InitialDelay / Ignorance Period (ms)" 
                                                                       FontWeight="Bold" 
                                                                       Foreground="White" 
                                                                       Margin="0,0,0,5"/>

