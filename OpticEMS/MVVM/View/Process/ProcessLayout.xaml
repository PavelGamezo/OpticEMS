<Page x:Class="OpticEMS.MVVM.View.Process.ProcessLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1200"
      Title="Process">

    <Grid>
        <xcad:DockingManager x:Name="DockManager">

            <xcad:DockingManager.Theme>
                <xcad:Vs2013DarkTheme/>
            </xcad:DockingManager.Theme>

            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Horizontal">

                    <xcad:LayoutDocumentPane>
                        <xcad:LayoutDocument Title="Process View" CanClose="False">

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="2*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Background="#1e1d1d"
                                      Margin="0,0,0,0">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" 
                                                Orientation="Horizontal">

                                        <Button Command="{Binding SelectedChannel.StartProcessCommand}"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#222120"
                                                HorizontalAlignment="Stretch">

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Grid Width="10" Height="10" Margin="0,0,10,0">
                                                    <Path Data="M3,3 L13,8 L3,13 Z" 
                                                          Fill="White" 
                                                          Stretch="Uniform"/>
                                                </Grid>
                                                <TextBlock Text="Start" 
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding SelectedChannel.PauseProcessCommand}"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#222120"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,5,5,5"
                                                Width="30">

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Viewbox Width="14" Height="14">
                                                    <Canvas Width="24" Height="24">
                                                        <Rectangle Canvas.Left="5" Canvas.Top="4" Width="4" Height="16" Fill="White" RadiusX="1" RadiusY="1"/>
                                                        <Rectangle Canvas.Left="15" Canvas.Top="4" Width="4" Height="16" Fill="White" RadiusX="1" RadiusY="1"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </StackPanel>

                                        </Button>

                                        <Button Command="{Binding SelectedChannel.StopProcessCommand}"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#222120"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,0"
                                                Width="30">

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Viewbox Width="16" 
                                                         Height="16">
                                                    <Canvas Width="24" 
                                                            Height="24"
                                                            Margin="10,5,0,0">
                                                        <Rectangle Width="18" Height="18"
                                                                   Fill="White"
                                                                   RadiusX="2"
                                                                   RadiusY="2"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </StackPanel>

                                        </Button>

                                        <Button Style="{StaticResource ActionButtonStyle}"
                                                Background="#222120"
                                                HorizontalAlignment="Stretch"
                                                Width="40">

                                            <Button.ContextMenu>
                                                <ContextMenu Style="{StaticResource ModernContextMenu}">

                                                    <MenuItem Header="CSV (.csv)" 
                                                              Command="{Binding SelectedChannel.ExportToCsvCommand}"/>

                                                    <MenuItem Header="Excel (.xlsx)" 
                                                              Command="{Binding SelectedChannel.ExportToExcelCommand}"/>

                                                    <MenuItem Header="Text (.txt)" 
                                                              Command="{Binding SelectedChannel.ExportToTxtCommand}"/>

                                                </ContextMenu>
                                            </Button.ContextMenu>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Viewbox Width="14" Height="14">
                                                    <Canvas Width="24" Height="24">

                                                        <Path Data="M12,4 L12,16 M8,12 L12,16 L16,12"
                                                              Stroke="White"
                                                              StrokeThickness="2"
                                                              StrokeLineJoin="Round"/>
                                                        <Path Data="M4,20 L20,20"
                                                              Stroke="White"
                                                              StrokeThickness="2"/>

                                                    </Canvas>
                                                </Viewbox>
                                            </StackPanel>
                                        </Button>

                                    </StackPanel>

                                    <ContentControl Grid.Row="1" 
                                                    Content="{Binding SelectedChannel.ProcessChartViewModel}" />

                                </Grid>

                                <Rectangle Grid.Row="1" 
                                           Height="10" 
                                           Fill="#1a1a1a"/>

                                <Border Grid.Row="2" 
                                        Background="#1f1f1f" 
                                        CornerRadius="3" 
                                        Padding="10"
                                        Margin="0,0,0,0">

                                    <ContentControl Grid.Row="2" 
                                                    Content="{Binding SelectedChannel.SpectrumChartViewModel}" />

                                </Border>
                            </Grid>
                        </xcad:LayoutDocument>
                    </xcad:LayoutDocumentPane>

                    <xcad:LayoutAnchorablePane DockWidth="360">
                        <xcad:LayoutAnchorable Title="Channels &amp; Details"
                                               CanClose="False"
                                               CanAutoHide="True"
                                               CanFloat="True">

                            <Grid Grid.Column="2" 
                                  Background="#262726"
                                  x:Name="SideMenuParent">

                                <Button x:Name="BtnToggleMenu"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Width="20" Height="40"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="-20,0,0,0"
                                        Background="#262726"
                                        Foreground="Gray"
                                        Content="▶"
                                        Cursor="Hand"
                                        Panel.ZIndex="10">

                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5,0,0,5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <Border Background="#262726" x:Name="SideContentBorder">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ListView Grid.Row="0"
                                                  Background="Transparent"
                                                  Height="Auto"
                                                  BorderThickness="0"
                                                  ItemsSource="{Binding Channels}"
                                                  SelectedItem="{Binding SelectedChannel}"
                                                  ItemContainerStyle="{StaticResource ModernListViewItemStyle}">

                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="4,2">
                                                        <Border x:Name="CardBorder" 
                                                                Background="#1f1f1f" 
                                                                CornerRadius="4" 
                                                                Padding="12,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Path Grid.Column="0" 
                                                                      Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5Z" 
                                                                      Fill="#858585" 
                                                                      Width="18" Height="18" 
                                                                      Stretch="Uniform" 
                                                                      Margin="0,0,12,0"
                                                                      x:Name="DeviceIcon"/>

                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                                                    <TextBlock Text="{Binding ChannelName}" 
                                                                               FontSize="13"
                                                                               FontWeight="Medium"
                                                                               Foreground="#E0E0E0"
                                                                               x:Name="NameText"/>

                                                                    <TextBlock Text="{Binding ProcessStatus}" 
                                                                               FontSize="10" 
                                                                               Foreground="#858585"
                                                                               Margin="0,2,0,0"/>
                                                                </StackPanel>

                                                                <Ellipse Grid.Column="2" 
                                                                         Width="8" Height="8" 
                                                                         Fill="#3498DB" 
                                                                         Margin="5,0,0,0">

                                                                    <Ellipse.Effect>
                                                                        <BlurEffect Radius="4"/>
                                                                    </Ellipse.Effect>

                                                                </Ellipse>
                                                            </Grid>
                                                        </Border>

                                                        <Border x:Name="SelectionIndicator" 
                                                                Width="3" 
                                                                HorizontalAlignment="Left" 
                                                                Background="#3498DB" 
                                                                CornerRadius="2,0,0,2"
                                                                Visibility="Collapsed"/>
                                                    </Grid>

                                                    <DataTemplate.Triggers>

                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                            <Setter TargetName="CardBorder" Property="Background" Value="#3d3d40"/>
                                                            <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="DeviceIcon" Property="Fill" Value="#3498DB"/>
                                                            <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                                        </DataTrigger>

                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <Border Grid.Row="1"
                                                BorderBrush="#2A2A2A" 
                                                BorderThickness="1"
                                                Padding="15"
                                                Margin="0 0 0 0" 
                                                Background="#262726">

                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" 
                                                                  Direction="450" 
                                                                  ShadowDepth="5" 
                                                                  Opacity="0.4"/>
                                            </Border.Effect>

                                            <StackPanel>
                                                <DockPanel LastChildFill="True" Margin="0,0,0,15">

                                                    <TextBlock Text="{Binding SelectedChannel.Recipe.Name, FallbackValue='No Recipe'}" 
                                                               Foreground="White" 
                                                               FontSize="14" 
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"/>
                                                </DockPanel>

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <ItemsControl Grid.Row="0" ItemsSource="{Binding SelectedChannel.Recipe.Wavelengths}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Column="0" 
                                                                               Text="Wavelength:" 
                                                                               Style="{StaticResource ParameterLabelStyle}"/>

                                                                    <StackPanel Grid.Column="1" 
                                                                                Orientation="Horizontal" 
                                                                                HorizontalAlignment="Right">

                                                                        <TextBlock Text="{Binding}" 
                                                                                   Style="{StaticResource ParameterValueStyle}"/>

                                                                        <TextBlock Text=" nm" 
                                                                                   Style="{StaticResource ParameterLabelStyle}" Margin="2,0,0,5"/>

                                                                    </StackPanel>

                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Grid Grid.Row="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Row="0" 
                                                                   Grid.Column="0" 
                                                                   Text="Initial Delay:" 
                                                                   Style="{StaticResource ParameterLabelStyle}"/>

                                                        <StackPanel Grid.Row="0" 
                                                                    Grid.Column="1" 
                                                                    Orientation="Horizontal" 
                                                                    HorizontalAlignment="Right">

                                                            <TextBlock Text="{Binding SelectedChannel.Recipe.InitialDelay}" 
                                                                       Style="{StaticResource ParameterValueStyle}"/>

                                                            <TextBlock Text=" ms" 
                                                                       Style="{StaticResource ParameterLabelStyle}" 
                                                                       Margin="2,0,0,5"/>

                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </xcad:LayoutAnchorable>
                    </xcad:LayoutAnchorablePane>

                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>
    </Grid>
</Page>