<Window x:Class="OpticEMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpticEMS"
        xmlns:vmset="clr-namespace:OpticEMS.MVVM.ViewModels.SettingsViewModels"
        xmlns:vmrec="clr-namespace:OpticEMS.MVVM.ViewModels.RecipeViewModels"
        xmlns:vmproc="clr-namespace:OpticEMS.MVVM.ViewModels.ProcessViewModels"
        xmlns:pproc="clr-namespace:OpticEMS.MVVM.View.Process"
        xmlns:pset="clr-namespace:OpticEMS.MVVM.View.Settings"
        xmlns:prec="clr-namespace:OpticEMS.MVVM.View.Recipe"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Background="#1C2833"
        WindowStyle="None"
        WindowState="Maximized"
        AllowsTransparency="True"
        Title="MainWindow" Height="800" Width="1300"
        FontFamily="Segoe UI Semibold">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vmset:CalibrationSettingsViewModel}">
            <pset:CalibrationSettings/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmset:ChamberSettingsViewModel}">
            <pset:ChamberSettings/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmproc:ProcessViewModel}">
            <pproc:Process/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmset:SettingsViewModel}">
            <pset:Settings/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmrec:RecipeViewModel}">
            <prec:Recipe/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmproc:SpectrumChartViewModel}">
            <pproc:SpectrumChart />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmproc:ProcessChartViewModel}">
            <pproc:ProcessChart />
        </DataTemplate>

        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <ContentPresenter x:Name="contentPresenter"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                            <Border x:Name="Underline"
                            Height="2"
                            Background="#3498DB"
                            VerticalAlignment="Bottom"
                            Opacity="0"/>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#ECF0F1"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                                    To="#ECF0F1"
                                                    Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                                    To="#BDBDBD"
                                                    Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border">
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" 
                                        Property="Background" 
                                        Value="#1f1f1f"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" 
                                        Property="Background" 
                                        Value="#1a1a1a"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.2"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.8"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.3"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#1a1a1a">
        <DockPanel Grid.ColumnSpan="3">
            <Border DockPanel.Dock="Top" 
                    Background="#1a1a1a" 
                    Height="40"
                    CornerRadius="0">

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding MoveWindowCommand}"/>
                </Border.InputBindings>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Grid.ColumnSpan="1">
                        <Grid Width="20" Height="20" Margin="25, 0, 5, 5" VerticalAlignment="Center">
                            <Ellipse>
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                        <GradientStop Color="#FF00B2FF" Offset="0.0"/>
                                        <GradientStop Color="#FF007ACC" Offset="0.5"/>
                                        <GradientStop Color="#FF003A66" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Fill="{x:Null}" Stroke="#FF1C2833" StrokeThickness="6"/>
                        </Grid>
                        <TextBlock Text="Optic EMS" 
                                   Margin="5, 0, 0, 0"
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   FontFamily="SF Pro"
                                   Foreground="#E8E9E8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0 ,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="Date: " 
                                   Foreground="#E8E9E8"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Semibold"/>

                        <TextBlock Text="{Binding CurrentTime}" 
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" 
                        Orientation="Horizontal">

                        <Button Command="{Binding MinimizeWindowCommand}"
                                Style="{StaticResource WindowControlButton}"
                                ToolTip="Свернуть"
                                Width="40"
                                Height="40">

                            <TextBlock Text="─" 
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>

                        <Button Command="{Binding MaximizeWindowCommand}"
                                Style="{StaticResource ButtonStyle}"
                                ToolTip="Развернуть"
                                Width="40"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Height="40">

                            <TextBlock Text="□" 
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </Button>

                        <Button Command="{Binding CloseWindowCommand}"
                                Style="{StaticResource ButtonStyle}"
                                ToolTip="Закрыть"
                                Width="40"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Height="40">

                            <TextBlock Text="✕" 
                                       FontSize="14"
                                       FontWeight="Bold" Width="20"/>

                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"  
                        Background="#1a1a1a"
                        Height="45" 
                        Margin="2,0,2,1"
                        CornerRadius="0">

                    <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center"
                                Height="45">

                        <ToggleButton Content="Process Monitoring"
                                      Style="{StaticResource TabButtonStyle}"
                                      Command="{Binding ShowSygnalCommand}"
                                      IsChecked="{Binding IsProcessSelected, Mode=OneWay}"
                                      Tag="Process"
                                      Width="220"/>

                        <ToggleButton Content="Recipe Settings"
                                      Style="{StaticResource TabButtonStyle}"
                                      Command="{Binding ShowRecipeCommand}"
                                      IsChecked="{Binding IsRecipeSelected, Mode=OneWay}"
                                      Tag="Recipe"
                                      Width="220"/>

                        <ToggleButton Content="Settings"
                                      Style="{StaticResource TabButtonStyle}"
                                      Command="{Binding ShowSettingsCommand}"
                                      IsChecked="{Binding IsSettingsSelected, Mode=OneWay}"
                                      Tag="Settings"
                                      Width="180"/>

                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#1e1d1d"
                        CornerRadius="0"
                        Margin="2">

                    <Frame x:Name="MainFrame" 
                           NavigationUIVisibility="Hidden"
                           Content="{Binding CurrentViewModel}"/>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
