<Page x:Class="OpticEMS.MVVM.View.Recipe.Recipe"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OpticEMS.MVVM.View.Recipe"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:converters="clr-namespace:OpticEMS.Common.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="Recipe">

    <Page.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#1a1a1a"
                Padding="25,5,5,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Process Recipes" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">

                    <Button Content="New recipe" 
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding NewRecipeCommand}"/>

                    <Button Content="Rename"
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RenameRecipeCommand}"/>

                    <Button Grid.Column="3" 
                            Content="Save" 
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding SaveRecipeCommand}"/>

                    <Button Grid.Column="3" 
                            Content="Save" 
                            Width="120"
                            Height="35"
                            Foreground="White"
                            Background="#222120"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ApplySelectedRecipeCommand}"/>

                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:RecipeFileManager Grid.Column="0"/>

            <Border Grid.Column="1" 
                    Background="#1f1f1f">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBarStyle}"/>
                    </ScrollViewer.Resources>

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <local:NameControl Grid.Row="0"/>

                        <local:SetupControl Grid.Row="1"/>

                        <local:WavelengthControl Grid.Row="2"/>
                        
                        <local:ProcessingModeControl Grid.Row="3"/>

                        <local:TimingParametersControl Grid.Row="4"/>

                        <local:PreprocessingParametersControl Grid.Row="5"/>

                        <local:DetectionParametersControl Grid.Row="6"/>

                        <local:OveretchingParametersControl Grid.Row="7"/>

                        <local:AnalysisParametersControl Grid.Row="8"/>
                        
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" 
                Background="#1f1f1f"
                Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal">

                    <Ellipse Width="10" 
                             Height="10" 
                             Fill="Green" 
                             Margin="0,0,8,0"/>

                    <TextBlock Text="System is ready"
                               Foreground="#999999"/>

                </StackPanel>

                <TextBlock Grid.Column="2" 
                           Foreground="#999999"> 
                    
                    <Run Text="Last modified: "/> 
                    <Run Text="{Binding SelectedRecipe.LastModifiedAt}"/>

                </TextBlock>

            </Grid>
        </Border>
    </Grid>
</Page>
