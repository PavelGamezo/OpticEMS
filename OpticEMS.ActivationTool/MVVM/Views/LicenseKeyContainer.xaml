<UserControl x:Class="OpticEMS.ActivationTool.MVVM.Views.LicenseKeyContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.ActivationTool.MVVM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="800"
             Background="#1a1a1a">

    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="GENERATED LICENSE KEY" 
                           Foreground="White" 
                           FontSize="11" 
                           FontWeight="Bold"
                           Margin="10,10,0,10"/>

                <TextBox Style="{StaticResource OpticTextBox}" 
                         Text="{Binding GeneratedKey, Mode=OneWay}"
                         Margin="10,0,10,0"
                         Height="150" 
                         TextWrapping="Wrap" 
                         IsReadOnly="True" 
                         FontFamily="Consolas" 
                         FontSize="13" 
                         Background="#0D0D0D" 
                         BorderBrush="#1C2833"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"/>
            </StackPanel>
            
            <StackPanel Grid.Row ="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,0,0,0">

                <Button Content="COPY KEY" 
                        Command="{Binding CopyCommand}"
                        Style="{StaticResource ActionButtonStyle}" 
                        Width="120" 
                        Background="#2C3E50" 
                        Foreground="White"
                        Margin="0,20,10,0"/>
                
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
