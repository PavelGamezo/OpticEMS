<UserControl x:Class="OpticEMS.MVVM.View.Process.ChannelDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Process"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="200">

    <Border Grid.Row="1"
            BorderBrush="#1f1f1f" 
            BorderThickness="1"
            Padding="15"
            Margin="0 0 0 0" 
            Background="#1f1f1f">

        <StackPanel>

                <DockPanel LastChildFill="True" Margin="0,0,0,15">
                    <TextBlock Text="{Binding Channel.Recipe.Name, FallbackValue='No Recipe'}"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding Channel.Recipe.Wavelengths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                           Text="Wavelength:"
                                           Style="{StaticResource ParameterLabelStyle}"/>

                                    <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">

                                        <TextBlock Text="{Binding}"
                                               Style="{StaticResource ParameterValueStyle}"/>

                                        <TextBlock Text=" nm"
                                               Style="{StaticResource ParameterLabelStyle}"
                                               Margin="2,0,0,5"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                               Text="Initial Delay:"
                               Style="{StaticResource ParameterLabelStyle}"/>

                        <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                            <TextBlock Text="{Binding Channel.Recipe.InitialDelay}"
                                   Style="{StaticResource ParameterValueStyle}"/>

                            <TextBlock Text=" ms"
                                   Style="{StaticResource ParameterLabelStyle}"
                                   Margin="2,0,0,5"/>
                        </StackPanel>
                    </Grid>
                </Grid>

            </StackPanel>
        </Border>
</UserControl>
