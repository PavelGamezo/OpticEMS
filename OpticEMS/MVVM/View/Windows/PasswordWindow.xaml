<Window x:Class="OpticEMS.MVVM.View.Windows.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent"
        ResizeMode="NoResize"
        Title="Elevated Access" 
        FontFamily="Segoe UI Semibold"
        Height="240" 
        Width="390">
    <Window.RenderTransform>
        <ScaleTransform x:Name="WindowScaleTransform" CenterX="195" CenterY="120"/>
    </Window.RenderTransform>

    <Window.Resources>
        <Storyboard x:Key="WindowOpeningAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:0.3"/>

            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.8" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.8" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowOpeningAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#1E1E1E" BorderBrush="#454545" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="4" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform Y="0"/>
        </Border.RenderTransform>

        <StackPanel Margin="20">
            <TextBlock Text="Elevated Access" 
                       Foreground="#007ACC" 
                       FontSize="18"
                       Margin="0,0,0,5"/>

            <TextBlock Text="Please enter your access key" 
                       Foreground="#888" 
                       FontSize="12"
                       Margin="0,0,0,15"/>

            <PasswordBox x:Name="PassBox" 
                         Height="35"
                         VerticalContentAlignment="Center"
                         Background="#2D2D2D"
                         Foreground="White" 
                         BorderBrush="#3E3E42" 
                         Padding="5" 
                         Margin="0,0,0,5"/>

            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="#F44336" 
                       FontSize="11" 
                       Height="16"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="85" Height="30"
                        Margin="0,0,10,0" 
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#007ACC"
                        Foreground="White"/>

                <Button Content="Verify"
                        Command="{Binding VerifyCommand}"
                        CommandParameter="{Binding ElementName=PassBox}"
                        IsDefault="True"
                        Width="85" Height="30"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#007ACC"
                        Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>