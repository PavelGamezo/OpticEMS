<UserControl x:Class="OpticEMS.MVVM.View.Process.Channel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Process"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Grid.Column="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#1f1f1f"
              Margin="0,0,0,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal">

                <Button Command="{Binding StartProcessCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Grid Width="10" Height="10" Margin="0,0,10,0">
                            <Path Data="M3,3 L13,8 L3,13 Z" 
                                  Fill="White" 
                                  Stretch="Uniform"/>
                        </Grid>
                        <TextBlock Text="Start" 
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding PauseProcessCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Margin="0,5,5,5"
                        Width="30">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="5" Canvas.Top="4" Width="4" Height="16" Fill="White" RadiusX="1" RadiusY="1"/>
                                <Rectangle Canvas.Left="15" Canvas.Top="4" Width="4" Height="16" Fill="White" RadiusX="1" RadiusY="1"/>
                            </Canvas>
                        </Viewbox>
                    </StackPanel>

                </Button>

                <Button Command="{Binding StopProcessCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,0"
                        Width="30">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="16" 
                                 Height="16">
                            <Canvas Width="24" 
                                    Height="24"
                                    Margin="10,5,0,0">
                                <Rectangle Width="18" Height="18"
                                           Fill="White"
                                           RadiusX="2"
                                           RadiusY="2"/>
                            </Canvas>
                        </Viewbox>
                    </StackPanel>

                </Button>

                <Button Style="{StaticResource ActionButtonStyle}"
                        Background="#222120"
                        HorizontalAlignment="Stretch"
                        Width="40">

                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ModernContextMenu}">

                            <MenuItem Header="CSV (.csv)" 
                                      Command="{Binding ExportToCsvCommand}"/>

                            <MenuItem Header="Excel (.xlsx)" 
                                      Command="{Binding ExportToExcelCommand}"/>

                            <MenuItem Header="Text (.txt)" 
                                      Command="{Binding ExportToTxtCommand}"/>

                        </ContextMenu>
                    </Button.ContextMenu>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">

                                <Path Data="M12,4 L12,16 M8,12 L12,16 L16,12"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"/>
                                <Path Data="M4,20 L20,20"
                                      Stroke="White"
                                      StrokeThickness="2"/>

                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Button>

            </StackPanel>

            <ContentControl Grid.Row="1" 
                Content="{Binding ProcessChartViewModel}" />

        </Grid>

        <Rectangle Grid.Row="1" 
                   Height="10" 
                   Fill="#2d2d30"/>

        <Border Grid.Row="2" 
                Background="#1f1f1f" 
                CornerRadius="3" 
                Padding="10"
                Margin="0,0,0,0">

            <ContentControl Grid.Row="2" 
                Content="{Binding SpectrumChartViewModel}" />

        </Border>
    </Grid>
</UserControl>
