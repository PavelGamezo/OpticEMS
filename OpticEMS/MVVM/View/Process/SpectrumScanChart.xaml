<UserControl x:Class="OpticEMS.MVVM.View.Process.SpectrumScanChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Process"
             xmlns:oxy="clr-namespace:OxyPlot.SkiaSharp.Wpf;assembly=OxyPlot.SkiaSharp.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <oxy:PlotView Model="{Binding PlotModel}" 
                  DefaultTrackerTemplate="{StaticResource ModernTrackerTemplate}"
                  Background="Transparent"/>
    </Grid>
</UserControl>
