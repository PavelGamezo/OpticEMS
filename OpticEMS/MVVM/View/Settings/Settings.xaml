<Page x:Class="OpticEMS.MVVM.View.Settings.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OpticEMS.MVVM.View.Settings"
      xmlns:viewmodels="clr-namespace:OpticEMS.MVVM.ViewModels.SettingsViewModels"
      xmlns:views="clr-namespace:OpticEMS.MVVM.View.Settings"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Title="Program Settings"
      Background="#1e1d1d"
      Foreground="White"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <Page.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="BorderBrush" Value="#2c2c2c"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <DataTemplate DataType="{x:Type viewmodels:ChamberSettingsViewModel}">
            <views:ChamberSettings />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:CalibrationSettingsViewModel}">
            <views:CalibrationSettings />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:LicenseSettingsViewModel}">
            <views:AboutTab />
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <TabControl Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    materialDesign:ColorZoneAssist.Mode="Standard"
                    Background="#1a1919"
                    TabStripPlacement="Left">

            <TabItem Width="200" Height="50" HorizontalAlignment="Stretch">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Chambers" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <ContentControl Content="{Binding ChamberSettingsViewModel}" Margin="16"/>
            </TabItem>

            <TabItem Width="200" Height="50" HorizontalAlignment="Stretch">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <materialDesign:PackIcon Kind="SineWave" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Calibration" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <ContentControl Content="{Binding CalibrationSettingsViewModel}" Margin="16"/>
            </TabItem>

            <TabItem Width="200" Height="50" HorizontalAlignment="Stretch">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <materialDesign:PackIcon Kind="About" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="About" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <ContentControl Content="{Binding LicenseSettingsViewModel}" Margin="16"/>
            </TabItem>

        </TabControl>
    </Grid>
</Page>