<UserControl x:Class="OpticEMS.MVVM.View.Recipe.WavelengthControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Recipe"
             xmlns:converters="clr-namespace:OpticEMS.Common.Helpers"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             mc:Ignorable="d" 
             d:DesignWidth="800">

    <UserControl.Resources>
        <converters:DoubleToStringConverter x:Key="DoubleToStringConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Padding="15,15,15,0">

        <StackPanel>

            <Grid>

                <TextBlock Text="Wavelength monitoring" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="White"
                           Margin="0,0,0,0"/>

                <Button Content="+ Add"
                        Style="{StaticResource ActionButtonStyle}"
                        Width="80"
                        Foreground="White"
                        Background="#272727"
                        Command="{Binding AddWavelengthCommand}" 
                        HorizontalAlignment="Right"/>

            </Grid>

            <ItemsControl ItemsSource="{Binding WavelengthItems}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border BorderBrush="#3E3E40" 
                                BorderThickness="1"
                                Margin="0,5,5,0"
                                Padding="10"
                                Background="#1E1E1E">

                            <Border.Effect>

                                <DropShadowEffect Color="Black" 
                                                  Direction="315" 
                                                  ShadowDepth="4" 
                                                  Opacity="0.6" 
                                                  BlurRadius="12"/>

                            </Border.Effect>

                            <StackPanel>

                                <Grid>

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock Text="Wavelength" 
                                                   FontSize="11" 
                                                   Foreground="#999999"/>

                                        <Border Margin="6,0,0,0" 
                                                Width="14" 
                                                Height="14" 
                                                CornerRadius="7" 
                                                Background="#444444" 
                                                Cursor="Help"
                                                VerticalAlignment="Center"
                                                ToolTipService.InitialShowDelay="100">

                                            <TextBlock Text="?" 
                                                       FontSize="10" 
                                                       FontWeight="Bold"
                                                       Foreground="#AAAAAA" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,1"/>

                                            <Border.ToolTip>

                                                <ToolTip Background="#252526" 
                                                         Foreground="White" 
                                                         BorderBrush="#454545"
                                                         Padding="10"
                                                         HasDropShadow="True">

                                                    <StackPanel Width="200">

                                                        <TextBlock Text="Target Wavelengths (nm)" 
                                                                   FontWeight="Bold" 
                                                                   Foreground="White" 
                                                                   Margin="0,0,0,5"/>

                                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                               Height="108"
                                                               Width="192"
                                                               Stretch="Uniform" 
                                                               Margin="0,5"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                                        <TextBlock Text="Specific spectral lines (in nanometers) monitored to track chemical species in the plasma." 
                                                                   Foreground="#CCCCCC" 
                                                                   FontSize="11" 
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                </ToolTip>

                                            </Border.ToolTip>

                                        </Border>
                                    </StackPanel>

                                    <Button Content="✕" 
                                            Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding DataContext.RemoveWavelengthCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            Width="15" 
                                            Height="15"
                                            Margin="0"
                                            HorizontalAlignment="Right" 
                                            Background="Transparent"
                                            Foreground="Gray"
                                            BorderThickness="0"
                                            CommandParameter="{Binding}"/>
                                </Grid>

                                <ComboBox Style="{StaticResource MaterialDarkComboBoxStyle}"
                                          Margin="0,5,0,5"
                                          ItemsSource="{Binding DataContext.SpectralLines, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding SelectedLine, Mode=TwoWay}"
                                          Text="{Binding Wavelength, Mode=TwoWay, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          TextSearch.TextPath="Wavelength"
                                          SelectedValuePath="Wavelength">

                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="WavelengthGroup"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Element}" 
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Wavelength, TargetNullValue='', StringFormat={}{0:F2}}"
                                                           Language="en-US"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="20,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock Text="Color" 
                                               FontSize="11"
                                               Margin="0,5,0,0"
                                               Foreground="#999999"/>

                                    <Border Margin="6,5,0,0" 
                                            Width="14" 
                                            Height="14" 
                                            CornerRadius="7" 
                                            Background="#444444" 
                                            Cursor="Help"
                                            VerticalAlignment="Center"
                                            ToolTipService.InitialShowDelay="100">

                                        <TextBlock Text="?" 
                                                   FontSize="10" 
                                                   FontWeight="Bold"
                                                   Foreground="#AAAAAA" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,1"/>

                                        <Border.ToolTip>

                                            <ToolTip Background="#252526" 
                                                     Foreground="White" 
                                                     BorderBrush="#454545"
                                                     Padding="10"
                                                     HasDropShadow="True">

                                                <StackPanel Width="200">
                                                    <TextBlock Text="Target colors" 
                                                               FontWeight="Bold" 
                                                               Foreground="White" 
                                                               Margin="0,0,0,5"/>

                                                    <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                           Height="108"
                                                           Width="192"
                                                           Stretch="Uniform" 
                                                           Margin="0,5"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                                    <TextBlock Text="Assigned colors for each wavelength to distinguish them on the real-time charts." 
                                                               Foreground="#CCCCCC" 
                                                               FontSize="11" 
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                            </ToolTip>

                                        </Border.ToolTip>

                                    </Border>
                                </StackPanel>

                                <xctk:ColorPicker SelectedColor="{Binding Color, UpdateSourceTrigger=PropertyChanged}" 
                                                  Height="30" Margin="0,5,0,0"
                                                  Style="{StaticResource DarkColorPicker}"/>

                                <StackPanel Visibility="{Binding DataContext.IsSingleWindowMode, 
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}, 
                                                        Converter={StaticResource InverseBooleanToVisibilityConverter}}">

                                    <StackPanel Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                            <TextBlock Text="Windows IN" 
                                                       FontSize="11"
                                                       Margin="0,0,0,0"
                                                       Foreground="#999999"/>

                                            <Border Margin="6,0,0,0" 
                                                    Width="14" 
                                                    Height="14" 
                                                    CornerRadius="7" 
                                                    Background="#444444" 
                                                    Cursor="Help"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.InitialShowDelay="100">

                                                <TextBlock Text="?" 
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           Foreground="#AAAAAA" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,1"/>

                                                <Border.ToolTip>

                                                    <ToolTip Background="#252526" 
                                                             Foreground="White" 
                                                             BorderBrush="#454545"
                                                             Padding="10"
                                                             HasDropShadow="True">

                                                        <StackPanel Width="200">

                                                            <TextBlock Text="Window In Count" 
                                                                       FontWeight="Bold" 
                                                                       Foreground="White" 
                                                                       Margin="0,0,0,5"/>

                                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                   Height="108"
                                                                   Width="192"
                                                                   Stretch="Uniform" 
                                                                   Margin="0,5"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                                            <TextBlock Text="The number of consecutive detection windows that must show the signal inside the detection band to confirm endpoint detection (stability after the drop)." 
                                                                       Foreground="#CCCCCC" 
                                                                       FontSize="11" 
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                    </ToolTip>

                                                </Border.ToolTip>

                                            </Border>

                                        </StackPanel>

                                        <TextBox Text="{Binding WindowInCount}" 
                                                 Background="#3E3E40"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 Padding="8"
                                                 Margin="0,5,0,0"/>

                                    </StackPanel>

                                    <StackPanel Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                            <TextBlock Text="Windows OUT" 
                                                       FontSize="11"
                                                       Foreground="#999999"/>

                                            <Border Margin="6,0,0,0" 
                                                    Width="14" 
                                                    Height="14" 
                                                    CornerRadius="7" 
                                                    Background="#444444" 
                                                    Cursor="Help"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.InitialShowDelay="100">

                                                <TextBlock Text="?" 
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           Foreground="#AAAAAA" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,0,1"/>

                                                <Border.ToolTip>

                                                    <ToolTip Background="#252526" 
                                                             Foreground="White" 
                                                             BorderBrush="#454545"
                                                             Padding="10"
                                                             HasDropShadow="True">

                                                        <StackPanel Width="200">

                                                            <TextBlock Text="Window Out Count" 
                                                                       FontWeight="Bold" 
                                                                       Foreground="White" 
                                                                       Margin="0,0,0,5"/>

                                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                   Height="108"
                                                                   Width="192"
                                                                   Stretch="Uniform" 
                                                                   Margin="0,5"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                                            <TextBlock Text="The number of consecutive detection windows that must show the signal outside the detection band to confirm the start of endpoint transition." 
                                                                       Foreground="#CCCCCC" 
                                                                       FontSize="11" 
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                    </ToolTip>

                                                </Border.ToolTip>

                                            </Border>
                                        </StackPanel>

                                        <TextBox Text="{Binding WindowOutCount}" 
                                                 Background="#3E3E40"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 Padding="8"
                                                 Margin="0,5,0,0"/>

                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock Text="Detection Window High"
                                                   FontSize="11"
                                                   Margin="0,10,0,0"
                                                   Foreground="#999999"/>

                                        <Border Margin="6,10,0,0" 
                                                Width="14" 
                                                Height="14" 
                                                CornerRadius="7" 
                                                Background="#444444" 
                                                Cursor="Help"
                                                VerticalAlignment="Center"
                                                ToolTipService.InitialShowDelay="100">

                                            <TextBlock Text="?" 
                                                       FontSize="10" 
                                                       FontWeight="Bold"
                                                       Foreground="#AAAAAA" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,1"/>

                                            <Border.ToolTip>

                                                <ToolTip Background="#252526" 
                                                         Foreground="White" 
                                                         BorderBrush="#454545"
                                                         Padding="10"
                                                         HasDropShadow="True">

                                                    <StackPanel Width="200">

                                                        <TextBlock Text="Detection Window High" 
                                                                   FontWeight="Bold" 
                                                                   Foreground="White"/>

                                                        <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                               Height="108"
                                                               Width="192"
                                                               Stretch="Uniform" 
                                                               Margin="0,5"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                                        <TextBlock Text="The height of the detection window as a percentage of the reference intensity (±%). 
                                                                        Defines the tolerance band around the reference signal. If the intensity moves outside this band, 
                                                                        it is considered a significant change." 
                                                                   Foreground="#CCCCCC" 
                                                                   FontSize="11" 
                                                                   TextWrapping="Wrap"/>

                                                    </StackPanel>

                                                </ToolTip>

                                            </Border.ToolTip>

                                        </Border>

                                    </StackPanel>

                                    <TextBox Grid.Column="0" 
                                             Text="{Binding SignalHigh, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#3E3E40"
                                             BorderThickness="0"
                                             Foreground="White"
                                             Padding="8"
                                             Margin="0,5,0,0"/>

                                    <TextBlock Text="%" 
                                               FontSize="10" 
                                               Foreground="#999999"
                                               Margin="0,2,0,0"/>

                                    <StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">

                                            <TextBlock Text="Detection Window Time"
                                                   FontSize="11"
                                                   Foreground="#999999"/>

                                            <Border Margin="6,0,0,0" 
                                                Width="14" 
                                                Height="14" 
                                                CornerRadius="7" 
                                                Background="#444444" 
                                                Cursor="Help"
                                                VerticalAlignment="Center"
                                                ToolTipService.InitialShowDelay="100">

                                                <TextBlock Text="?" 
                                                       FontSize="10" 
                                                       FontWeight="Bold"
                                                       Foreground="#AAAAAA" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,1"/>

                                                <Border.ToolTip>

                                                    <ToolTip Background="#252526" 
                                                         Foreground="White" 
                                                         BorderBrush="#454545"
                                                         Padding="10"
                                                         HasDropShadow="True">

                                                        <StackPanel Width="200">

                                                            <TextBlock Text="Detection Window Time / Cycle Time" 
                                                                       FontWeight="Bold" 
                                                                       Foreground="White" 
                                                                       Margin="0,0,0,5"/>

                                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                                   Height="108"
                                                                   Width="192"
                                                                   Stretch="Uniform" 
                                                                   Margin="0,5"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                                            <TextBlock Text="This parameter sets the heartbeat of the detection algorithm. Minimum time (in milliseconds) during which the signal must remain within the detection window to be considered stable. The result must remain stable for {WindowOutCount} consecutive cycles to trigger the process is in stable or to stop it." 
                                                                       Foreground="#CCCCCC" 
                                                                       FontSize="11" 
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                    </ToolTip>

                                                </Border.ToolTip>

                                            </Border>

                                        </StackPanel>

                                        <TextBox Grid.Column="0" 
                                                 Text="{Binding DetectionWindowTime, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#3E3E40"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 Padding="8"
                                                 Margin="0,5,0,0"/>

                                        <TextBlock Text="ms" 
                                                   FontSize="10" 
                                                   Foreground="#999999"
                                                   Margin="0,2,0,0"/>

                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Visibility="{Binding IsSingleWindowMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,5,0,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" 
                                Grid.Column="0" 
                                Margin="0,10,5,0">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="Detection Window Time" 
                                       FontSize="11" 
                                       Foreground="#999999"/>

                            <Border Margin="6,0,0,0" 
                                    Width="14" 
                                    Height="14" 
                                    CornerRadius="7" 
                                    Background="#444444" 
                                    Cursor="Help"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="100">

                                <TextBlock Text="?" 
                                           FontSize="10" 
                                           FontWeight="Bold"
                                           Foreground="#AAAAAA" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,1"/>

                                <Border.ToolTip>

                                    <ToolTip Background="#252526" 
                                             Foreground="White" 
                                             BorderBrush="#454545"
                                             Padding="10"
                                             HasDropShadow="True">

                                        <StackPanel Width="200">

                                            <TextBlock Text="Detection Window Time / Cycle Time" 
                                                       FontWeight="Bold" 
                                                       Foreground="White" 
                                                       Margin="0,0,0,5"/>

                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                   Height="108"
                                                   Width="192"
                                                   Stretch="Uniform" 
                                                   Margin="0,5"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <TextBlock Text="This parameter sets the heartbeat of the detection algorithm. Minimum time (in milliseconds) during which the signal must remain within the detection window to be considered stable. The result must remain stable for {WindowOutCount} consecutive cycles to trigger the process is in stable or to stop it." 
                                                       Foreground="#CCCCCC" 
                                                       FontSize="11" 
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                    </ToolTip>

                                </Border.ToolTip>

                            </Border>

                        </StackPanel>

                        <TextBox Text="{Binding CommonWindowTime}" 
                                 Background="#3E3E40"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Padding="8"
                                 Margin="0,5,0,0"/>

                        <TextBlock Text="ms" 
                                   FontSize="10" 
                                   Foreground="#999999"
                                   Margin="0,2,0,0"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,10,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <TextBlock Text="Detection Window High" 
                                       FontSize="11"
                                       Foreground="#999999"/>

                            <Border Margin="6,0,0,0" 
                                    Width="14" 
                                    Height="14" 
                                    CornerRadius="7" 
                                    Background="#444444" 
                                    Cursor="Help"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="100">

                                <TextBlock Text="?" 
                                           FontSize="10" 
                                           FontWeight="Bold"
                                           Foreground="#AAAAAA" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,1"/>

                                <Border.ToolTip>

                                    <ToolTip Background="#252526" 
                                             Foreground="White" 
                                             BorderBrush="#454545"
                                             Padding="10"
                                             HasDropShadow="True">

                                        <StackPanel Width="200">

                                            <TextBlock Text="Detection Window High" 
                                                       FontWeight="Bold" 
                                                       Foreground="White" 
                                                       Margin="0,0,0,5"/>

                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                   Height="108"
                                                   Width="192"
                                                   Stretch="Uniform" 
                                                   Margin="0,5"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <TextBlock Text="The height of the detection window as a percentage of the reference intensity (±%). 
                                                            Defines the tolerance band around the reference signal. If the intensity moves outside this band, 
                                                            it is considered a significant change." 
                                                       Foreground="#CCCCCC" 
                                                       FontSize="11" 
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                    </ToolTip>

                                </Border.ToolTip>

                            </Border>
                        </StackPanel>

                        <TextBox Grid.Column="0" 
                                 Text="{Binding CommonSignalHigh, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#3E3E40"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Padding="8"
                                 Margin="0,5,0,0"/>

                        <TextBlock Text="%" 
                                   FontSize="10" 
                                   Foreground="#999999"
                                   Margin="0,2,0,0"/>

                    </StackPanel>

                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,10,5,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <TextBlock Text="Windows IN" 
                                       FontSize="11"
                                       Margin="0,0,0,0"
                                       Foreground="#999999"/>

                            <Border Margin="6,0,0,0" 
                                    Width="14" 
                                    Height="14" 
                                    CornerRadius="7" 
                                    Background="#444444" 
                                    Cursor="Help"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="100">

                                <TextBlock Text="?" 
                                           FontSize="10" 
                                           FontWeight="Bold"
                                           Foreground="#AAAAAA" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,1"/>

                                <Border.ToolTip>

                                    <ToolTip Background="#252526" 
                                             Foreground="White" 
                                             BorderBrush="#454545"
                                             Padding="10"
                                             HasDropShadow="True">

                                        <StackPanel Width="200">

                                            <TextBlock Text="Window In Count" 
                                                       FontWeight="Bold" 
                                                       Foreground="White" 
                                                       Margin="0,0,0,5"/>

                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                   Height="108"
                                                   Width="192"
                                                   Stretch="Uniform" 
                                                   Margin="0,5"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <TextBlock Text="The number of consecutive detection windows that must show the signal inside the detection band to confirm endpoint detection (stability after the drop)." 
                                                       Foreground="#CCCCCC" 
                                                       FontSize="11" 
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                    </ToolTip>

                                </Border.ToolTip>

                            </Border>

                        </StackPanel>

                        <TextBox Text="{Binding CommonWindowIn}" 
                                 Background="#3E3E40"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Padding="8"
                                 Margin="0,5,0,0"/>

                        <TextBlock Text="" 
                                   FontSize="10" 
                                   Foreground="#999999"
                                   Margin="0,2,0,0"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,10,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <TextBlock Text="Windows OUT" 
                                       FontSize="11"
                                       Foreground="#999999"/>

                            <Border Margin="6,0,0,0" 
                                    Width="14" 
                                    Height="14" 
                                    CornerRadius="7" 
                                    Background="#444444" 
                                    Cursor="Help"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="100">

                                <TextBlock Text="?" 
                                           FontSize="10" 
                                           FontWeight="Bold"
                                           Foreground="#AAAAAA" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,1"/>

                                <Border.ToolTip>

                                    <ToolTip Background="#252526" 
                                             Foreground="White" 
                                             BorderBrush="#454545"
                                             Padding="10"
                                             HasDropShadow="True">

                                        <StackPanel Width="200">

                                            <TextBlock Text="Window Out Count" 
                                                       FontWeight="Bold" 
                                                       Foreground="White" 
                                                       Margin="0,0,0,5"/>

                                            <Image Source="pack://application:,,,/Common/Images/splash.png"
                                                   Height="108"
                                                   Width="192"
                                                   Stretch="Uniform" 
                                                   Margin="0,5"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <TextBlock Text="The number of consecutive detection windows that must show the signal outside the detection band to confirm the start of endpoint transition." 
                                                       Foreground="#CCCCCC" 
                                                       FontSize="11" 
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                    </ToolTip>

                                </Border.ToolTip>

                            </Border>
                        </StackPanel>

                        <TextBox Text="{Binding CommonWindowOut}" 
                                 Background="#3E3E40"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Padding="8"
                                 Margin="0,5,0,0"/>

                    </StackPanel>

                </Grid>

            </StackPanel>

            <StackPanel Orientation="Horizontal" 
                        VerticalAlignment="Center">

                <TextBlock Text="Autocalibration" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           Foreground="White"
                           Margin="0,15,0,0"/>

                <Border Margin="6,17,0,0" 
                        Width="14" 
                        Height="14" 
                        CornerRadius="7" 
                        Background="#444444" 
                        Cursor="Help"
                        VerticalAlignment="Center"
                        ToolTipService.InitialShowDelay="100">

                    <TextBlock Text="?" 
                               FontSize="10" 
                               FontWeight="Bold"
                               Foreground="#AAAAAA" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Margin="0,0,0,1"/>

                    <Border.ToolTip>

                        <ToolTip Background="#252526" 
                                 Foreground="White" 
                                 BorderBrush="#454545"
                                 Padding="10"
                                 HasDropShadow="True">

                            <StackPanel Width="220">

                                <TextBlock Text="Automatic Peak Alignment" 
                                           FontWeight="Bold" 
                                           Foreground="White"
                                           Margin="0,0,0,5"/>

                                <TextBlock Text="Enables automatic center-wavelength tracking. The system scans a ±1 nm range around the target wavelength to lock onto the actual intensity peak." 
                                           Foreground="#CCCCCC"
                                           FontSize="11" 
                                           TextWrapping="Wrap" 
                                           Margin="0,5,0,0"/>

                                <TextBlock Text="Ensures monitoring always stays on the highest point of the emission line. Corrects for pixel shifts caused by spectrometer temperature changes." 
                                           Foreground="#888888" 
                                           FontSize="11" 
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Note: The system will search within a ~2 nm window to establish the reference anchor point." 
                                           Foreground="#888888"
                                           FontStyle="Italic" 
                                           FontSize="10" 
                                           TextWrapping="Wrap" 
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </ToolTip>

                    </Border.ToolTip>

                </Border>

            </StackPanel>

            <ComboBox 
                      Background="#3E3E40"
                      BorderThickness="0"
                      Foreground="White"
                      Padding="8"
                      Margin="0,10,0,0"
                      ItemsSource="{Binding YesNoOptions}"
                      SelectedItem="{Binding SelectedAutocalibrationText}"
                      Height="32"/>

        </StackPanel>

    </Border>

</UserControl>
