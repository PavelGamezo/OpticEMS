<UserControl x:Class="OpticEMS.MVVM.View.Settings.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Settings"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             Foreground="White"
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            
            <Style x:Key="FlatButton" TargetType="{x:Type RadioButton}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignDarkSeparatorBackground}" />
                <Setter Property="BorderThickness" Value="0,0,0,0" />
                <Setter Property="BorderBrush" Value="Transparent" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RadioButton}">
                            
                            <Border x:Name="Border"
                                    Margin="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Border>

                            <ControlTemplate.Triggers>
                                
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentColorBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource AccentColorBrush}" />
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource GrayBrush2}" />
                                </Trigger>
                                
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="MaterialDesignTabItemHeaderTemplate">
                <DockPanel LastChildFill="True">
                    
                    <RadioButton HorizontalContentAlignment="Stretch"
                                 VerticalContentAlignment="Stretch"
                                 IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type TabItem}}, Path=IsSelected}"
                                 Style="{StaticResource FlatButton}">
                        
                        <materialDesign:Ripple HorizontalContentAlignment="Stretch"
                                               VerticalContentAlignment="Stretch"
                                               Feedback="{StaticResource AccentColorBrush}"
                                               SnapsToDevicePixels="True">
                            
                            <StackPanel HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Orientation="Horizontal">

                                <TextBlock Margin="0"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Text="{Binding}"/>
                                
                            </StackPanel>
                        </materialDesign:Ripple>
                    </RadioButton>
                </DockPanel>
            </DataTemplate>


        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical" Margin="20,0,10,10" HorizontalAlignment="Left" Width="350">

        <DockPanel>
            <Image Source="/Common/Images/endpoint_logo.png" HorizontalAlignment="Left" Width="152" Height="182" />
            <StackPanel Margin="5,5" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding Title}" FontSize="22" 
                           HorizontalAlignment="Center" VerticalAlignment="Top" />
                <TextBlock Text="{Binding ProjectVersion}" FontSize="12" 
                           HorizontalAlignment="Center" VerticalAlignment="Top" />
            </StackPanel>
        </DockPanel>
        <StackPanel Orientation="Horizontal" Margin="-4,0,0,0">
            <Label Content="{Binding Copyright}" FontSize="12"
                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
            <Label Content="{Binding Company}" FontSize="12"
                   Foreground="{DynamicResource MaterialDesignBodyLight}" />

        </StackPanel>

        <TextBlock Text="License information" Margin="0,15" FontSize="18" />

        <Border Background="{DynamicResource MaterialDesignDarkSeparatorBackground}" 
                CornerRadius="4" Padding="5">
            
            <RichTextBox Height="Auto" HorizontalAlignment="Left" 
                         IsReadOnly="True" Background="Transparent"
                         FontFamily="{materialDesign:MaterialDesignFont}"
                         Padding="5"
                         BorderThickness="0">
                <FlowDocument>
                    <Paragraph>
                        <Run Text="{Binding Edition}"
                             Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Paragraph>
                    <Paragraph>
                        <Run Text="{Binding Description}"
                             Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Paragraph>
                    <Paragraph>
                        <Run Text="{Binding ProjectVersion}"
                             Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
        </Border>

        <TextBlock Text="Update" Margin="5,15,5,15" FontSize="18" />

        <Button Content="Update Software"
                Style="{StaticResource ActionButtonStyle}"
                Foreground="#10505b"
                Background="Transparent"
                FontSize="14"
                Command="{Binding OpenUploadWindowCommand}" 
                HorizontalAlignment="Left"
                Margin="5" HorizontalContentAlignment="Right" />
    </StackPanel>
</UserControl>
