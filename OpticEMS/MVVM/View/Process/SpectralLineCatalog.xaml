<UserControl x:Class="OpticEMS.MVVM.View.Process.SpectralLineCatalog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="350">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryAccent" Color="#007ACC"/>
        <SolidColorBrush x:Key="BgDark" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgLighter" Color="#2D2D30"/>
        <SolidColorBrush x:Key="TextMuted" Color="#969696"/>
        <SolidColorBrush x:Key="TextMain" Color="#E0E0E0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="CenterElementStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A1A1A"/>
                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#37373D"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#37373D"/>
            </Style.Resources>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#434346"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="RepeatButton">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="RepeatButton">
                                <Border Background="#3E3E42" Height="4"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource BgLighter}" 
                Margin="12" 
                Padding="16" 
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Element" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Grid.Column="1" Foreground="Black" ItemsSource="{Binding AvailableElements}" SelectedItem="{Binding SelectedElement}"/>

                    <TextBlock Text="Ion" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Grid.Column="4" Foreground="Black" ItemsSource="{Binding AvailableIonizations}" SelectedItem="{Binding SelectedIonization}"/>
                </Grid>

                <StackPanel>
                    <DockPanel LastChildFill="True">
                        <TextBlock Text="Wavelength Range" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Background="{StaticResource PrimaryAccent}" CornerRadius="3" Padding="5,1">
                                <TextBlock Text="{Binding MinWavelength, StringFormat={}{0:F0}}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="-" VerticalAlignment="Center" Margin="4,0"/>
                            <Border Background="{StaticResource PrimaryAccent}" CornerRadius="3" Padding="5,1">
                                <TextBlock Text="{Binding MaxWavelength, StringFormat={}{0:F0}}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text=" nm" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <Slider Minimum="200" Maximum="800" 
                            Value="{Binding MinWavelength}" 
                            Margin="0,12,0,0"
                            TickPlacement="None"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" 
                  Margin="12,0,12,12"
                  Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding SpectralLines}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>

                <DataGridTemplateColumn Width="50" Header="Type">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Ellipse Width="22" Height="22" Fill="{Binding LineBrush}">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="{Binding Element}" 
                                           Foreground="White" 
                                           FontSize="9" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                           FontWeight="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Element" 
                                    Binding="{Binding Element}" 
                                    Width="*" 
                                    ElementStyle="{StaticResource CenterElementStyle}"/>

                <DataGridTextColumn Header="λ (nm)" 
                                    Binding="{Binding Wavelength, StringFormat={}{0:F2}}" 
                                    Width="100" 
                                    ElementStyle="{StaticResource CenterElementStyle}"/>

                <DataGridTextColumn Header="Ionization" 
                                    Binding="{Binding Ionization}" 
                                    Width="80" 
                                    ElementStyle="{StaticResource CenterElementStyle}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>