<Window x:Class="OpticEMS.MVVM.View.Windows.ApplicationMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpticEMS.MVVM.View.Windows"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent"
        Opacity="0"
        ResizeMode="NoResize"
        Title="ApplicationMessageBox" Height="180" Width="350">
    
    <Window.Resources>
        <Storyboard x:Key="WindowOpeningAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:0.3"/>

            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.8" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.8" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowOpeningAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#1E1E1E" BorderBrush="#454545" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="4" Color="Black"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform Y="0"/>
        </Border.RenderTransform>

        <Grid Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="15,15,15,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="IconTextBlock" Text="&#xEA39;" 
                           FontFamily="Segoe MDL2 Assets" Foreground="#F48771" 
                           Margin="0,5,0,0"
                           FontSize="18" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock x:Name="MessageTextBlock" Text="" 
                               Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="14" FontWeight="SemiBold"/>

                    <Expander x:Name="DetailsExpander" Header="Show Details" Foreground="#858585" 
                              FontSize="11" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBox x:Name="DetailsTextBox" IsReadOnly="True" Background="#252526" 
                                 Foreground="#858585" BorderThickness="1" BorderBrush="#333333" 
                                 FontSize="11" TextWrapping="Wrap" MaxHeight="120" 
                                 Margin="0,5,0,0" Padding="5" FontFamily="Consolas" VerticalScrollBarVisibility="Auto"/>
                    </Expander>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="#1E1E1E" Padding="15,5,15,15">
                <Grid>
                    <Button x:Name="CopyButton" Content="Copy Details" HorizontalAlignment="Left"
                            Foreground="#3794FF" Background="Transparent" BorderThickness="0"
                            FontSize="11" Cursor="Hand" Click="Copy_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        
                        <Button Content="OK" Width="80" 
                                Height="26" 
                                IsDefault="True" 
                                Click="Ok_Click" 
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#007ACC"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                FontSize="12">
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
