<UserControl x:Class="OpticEMS.MVVM.View.Process.ChannelDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:OpticEMS.Common.Helpers"
             mc:Ignorable="d" 
             d:DesignWidth="320">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </UserControl.Resources>

    <Border Background="#1f1f1f" BorderBrush="#2d2d30" BorderThickness="1" Padding="12,12,0,12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBarStyle}"/>
            </ScrollViewer.Resources>
            
            <StackPanel>

                <TextBlock Text="{Binding Channel.Recipe.Name, FallbackValue='No Recipe Selected'}" 
                           FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                <Rectangle Height="1" Fill="#2d2d30" Margin="0,0,0,12"/>

                <TextBlock Text="RECIPE PARAMETERS" 
                           Foreground="#aaaaaa" FontSize="10" FontWeight="DemiBold" Margin="0,0,0,8"/>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Recipe ID" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.RecipeId}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock Text="OPTICAL SETTINGS" 
                           Foreground="#aaaaaa" FontSize="10" FontWeight="DemiBold" Margin="0,16,0,8"/>

                <ItemsControl ItemsSource="{Binding Channel.Recipe.Wavelengths}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,3,10,0">
                                <TextBlock Text="Wavelength" Style="{StaticResource ParameterLabelStyle}"/>
                                <TextBlock Text="{Binding StringFormat='{}{0} nm'}" 
                                           Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="PROCESSING MODE" 
                           Foreground="#aaaaaa" 
                           FontSize="10" 
                           FontWeight="DemiBold" 
                           Margin="0,16,0,8"/>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Active Mode" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.ProcessingModeDisplay}" 
                               Style="{StaticResource ParameterValueStyle}" 
                               HorizontalAlignment="Right"
                               FontWeight="Medium"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0" Visibility="{Binding Channel.Recipe.IsCombinedMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Combined Expression" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.CombinedExpression}" 
                               Style="{StaticResource ParameterValueStyle}" 
                               HorizontalAlignment="Right"
                               Foreground="#50fa7b"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0" Visibility="{Binding Channel.Recipe.IsRatioMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Mode Type" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="Ratio (A/B)" 
                               Style="{StaticResource ParameterValueStyle}" 
                               HorizontalAlignment="Right"
                               Foreground="#50fa7b"/>
                </DockPanel>

                <TextBlock Text="PROCESS TIMING" 
                           Foreground="#aaaaaa" FontSize="10" FontWeight="DemiBold" Margin="0,16,0,8"/>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Initial Delay" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.InitialDelay, StringFormat='{}{0} ms'}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Max Process Time" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.MaxEndpointTime, StringFormat='{}{0} ms'}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock Text="DETECTION ALGORITHM" 
                           Foreground="#aaaaaa" FontSize="10" FontWeight="DemiBold" Margin="0,16,0,8"/>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Window Time" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.DetectionWindowTime, StringFormat='{}{0} ms'}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Window In / Out" Style="{StaticResource ParameterLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Channel.Recipe.WindowInCount}" Style="{StaticResource ParameterValueStyle}"/>
                        <TextBlock Text=" / " Foreground="#666666"/>
                        <TextBlock Text="{Binding Channel.Recipe.WindowOutCount}" Style="{StaticResource ParameterValueStyle}"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock Text="PREPROCESSING PARAMETERS" 
                           Foreground="#aaaaaa" FontSize="10" FontWeight="DemiBold" Margin="0,16,0,8"/>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Magnetic Field Period" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.MagneticFieldPeriodMs, StringFormat='{}{0} ms'}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Field Periods To Average" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.FieldPeriodsToAverage}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Derivative Enabled:" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ParameterValueStyle}">
                                <Setter Property="Text" Value="Disabled"/>
                                <Setter Property="Foreground" Value="#ff5555"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Channel.Recipe.DerivativeEnabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                        <Setter Property="Foreground" Value="#50fa7b"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>

                <DockPanel Margin="0,3,10,0" 
                           Visibility="{Binding Channel.Recipe.OverEtchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Derivative Points" Style="{StaticResource ParameterLabelStyle}"/>
                                    <TextBlock Text="{Binding Channel.Recipe.DerivativePoints}" 
                                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock Text="ADDITIONAL FEATURES" 
                           Foreground="#aaaaaa" FontSize="10" FontWeight="DemiBold" Margin="0,20,0,8"/>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Autocalibration:" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ParameterValueStyle}">
                                <Setter Property="Text" Value="Disabled"/>
                                <Setter Property="Foreground" Value="#ff5555"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Channel.Recipe.AutocalibrationEnabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                        <Setter Property="Foreground" Value="#50fa7b"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="Over Etch Enabled:" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ParameterValueStyle}">
                                <Setter Property="Text" Value="Disabled"/>
                                <Setter Property="Foreground" Value="#ff5555"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Channel.Recipe.OverEtchEnabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                        <Setter Property="Foreground" Value="#50fa7b"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>

                <DockPanel Margin="0,3,10,0" 
                           Visibility="{Binding Channel.Recipe.OverEtchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Over Etch Value" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.OverEtchValue, StringFormat='{}{0} s'}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

                <DockPanel Margin="0,3,10,0">
                    <TextBlock Text="PCA Enabled:" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ParameterValueStyle}">
                                <Setter Property="Text" Value="Disabled"/>
                                <Setter Property="Foreground" Value="#ff5555"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Channel.Recipe.PcaEnabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                        <Setter Property="Foreground" Value="#50fa7b"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>

                <DockPanel Margin="0,3,10,0" 
                           Visibility="{Binding Channel.Recipe.PcaEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="PCA Components" Style="{StaticResource ParameterLabelStyle}"/>
                    <TextBlock Text="{Binding Channel.Recipe.PcaComponents}" 
                               Style="{StaticResource ParameterValueStyle}" HorizontalAlignment="Right"/>
                </DockPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>