<UserControl x:Class="OpticEMS.MVVM.View.Process.SpectralLineCatalog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="350">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="PrimaryAccent" Color="#007ACC"/>
        <SolidColorBrush x:Key="BgDark" Color="#1f1f1f"/>
        <SolidColorBrush x:Key="BgLighter" Color="#272727"/>
        <SolidColorBrush x:Key="TextMuted" Color="#969696"/>
        <SolidColorBrush x:Key="TextMain" Color="#E0E0E0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="CenterElementStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MaterialDarkCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="wpf:CheckBoxAssist.CheckBoxSize" Value="16"/>
        </Style>

        <Style x:Key="MaterialDarkSliderStyle" TargetType="Slider" BasedOn="{StaticResource MaterialDesignDiscreteSlider}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryAccent}"/>
        </Style>

        <Style x:Key="MaterialDarkComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignFilledComboBox}">
            <Style.Resources>
                <CornerRadius x:Key="MaterialDesignFilledCornerRadius">0</CornerRadius>
            </Style.Resources>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="wpf:TextFieldAssist.DecorationVisibility" Value="Collapsed"/>
            <Setter Property="wpf:TextFieldAssist.HasClearButton" Value="False"/>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>

            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#272727"/>
                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgLighter}" Margin="12" Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBlock Text="Element" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextMuted}"/>
                        <ComboBox ItemsSource="{Binding AvailableElements}"
                                  SelectedItem="{Binding SelectedElement}"
                                  Style="{StaticResource MaterialDarkComboBoxStyle}"
                                  Width="80"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding OpenAddFormCommand}"
                            Height="24" 
                            Padding="8,0" 
                            FontSize="11" 
                            Content="New Line">
                        
                    </Button>
                </Grid>

                <StackPanel Margin="0,0,0,5">
                    <DockPanel LastChildFill="True">
                        <TextBlock Text="Wavelength Range" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Padding="5,1">
                                <TextBlock Text="{Binding MinWavelength, StringFormat={}{0:F0}}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="-" VerticalAlignment="Center" Margin="4,0"/>
                            <Border Padding="5,1">
                                <TextBlock Text="{Binding MaxWavelength, StringFormat={}{0:F0}}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text=" nm" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </DockPanel>

                    <Slider Minimum="200" Maximum="800" Value="{Binding MinWavelength}" Style="{StaticResource MaterialDarkSliderStyle}" Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel Visibility="{Binding IsAddFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Separator Background="#3F3F46" Margin="0,12"/>
                    <TextBlock Text="Create new Spectral Line" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Element" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewElement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignTextBox}"
                                     Foreground="White" CaretBrush="{StaticResource PrimaryAccent}"
                                     Margin="0,10,0,0"
                                     Height="25" VerticalContentAlignment="Center" Padding="4,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                            <TextBlock Text="λ (nm)" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewWavelengthText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignTextBox}"
                                     Foreground="White" CaretBrush="{StaticResource PrimaryAccent}"
                                     Height="25" VerticalContentAlignment="Center" 
                                     Margin="0,10,0,0" Padding="4,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Color" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <xctk:ColorPicker SelectedColor="{Binding NewLineColor, UpdateSourceTrigger=PropertyChanged}" 
                                              Height="30" Margin="0,5,0,0"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              Foreground="White"
                                              Style="{StaticResource DarkColorPicker}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Command="{Binding CloseAddFormCommand}" 
                                Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}" 
                                Foreground="{StaticResource TextMuted}" Height="26" Padding="8,0" Margin="0,0,8,0"/>

                        <Button Command="{Binding SaveNewLineCommand}" 
                                Content="Save Line" Style="{StaticResource ActionButtonStyle}" 
                                Background="{StaticResource PrimaryAccent}" Foreground="White" Height="26" Padding="12,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" Margin="12,0,12,12" Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding SpectralLines}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Selected" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" ElementStyle="{StaticResource MaterialDarkCheckBoxStyle}" EditingElementStyle="{StaticResource MaterialDarkCheckBoxStyle}"/>
                <DataGridTemplateColumn Header="Type" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Ellipse Width="18" Height="18" Fill="{Binding LineBrush}"/>
                                <TextBlock Text="{Binding Element}" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="λ (nm)" Width="2*" Binding="{Binding Wavelength, StringFormat={}{0:F2}}" ElementStyle="{StaticResource MaterialDesignTextBlock}"/>
                <DataGridTemplateColumn Header="Action"  Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Foreground="White"
                                    Background="Transparent"
                                    Height="22"
                                    Width="22"
                                    Padding="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Center"
                                    Command="{Binding DataContext.DeleteLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>