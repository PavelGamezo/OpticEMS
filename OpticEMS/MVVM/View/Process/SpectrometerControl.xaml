<UserControl x:Class="OpticEMS.MVVM.View.Process.SpectrometerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpticEMS.MVVM.View.Process"
             mc:Ignorable="d" 
             d:DesignWidth="800">
    
    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" 
                        Grid.Column="0" 
                        Margin="0,0,5,0">

                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center">

                    <TextBlock Text="Exposure Time" 
                               FontSize="11" 
                               Foreground="#999999"/>

                    <Border Margin="6,0,0,0" 
                            Width="14" 
                            Height="14" 
                            CornerRadius="7" 
                            Background="#444444" 
                            Cursor="Help"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="100">

                        <TextBlock Text="?" 
                                   FontSize="10" 
                                   FontWeight="Bold"
                                   Foreground="#AAAAAA" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,1"/>

                        <Border.ToolTip>

                            <ToolTip Background="#252526" 
                                     Foreground="White" 
                                     BorderBrush="#454545"
                                     Padding="10"
                                     HasDropShadow="True">

                                <StackPanel Width="200">

                                    <TextBlock Text="Exposure Time (ms)" 
                                               FontWeight="Bold" 
                                               Foreground="White" 
                                               Margin="0,0,0,5"/>

                                    <Image Source="pack://application:,,,/Common/Images/splash.png"
                                           Height="108"
                                           Width="192"
                                           Stretch="Uniform" 
                                           Margin="0,5"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                    <TextBlock Text="The amount of time the spectrometer sensor collects light for a single scan. Higher values increase signal but slow down the sampling rate." 
                                               Foreground="#CCCCCC" 
                                               FontSize="11" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                            </ToolTip>

                        </Border.ToolTip>

                    </Border>
                </StackPanel>

                <TextBox Text="{Binding ExposureMs}" 
                         Background="#3E3E40"
                         BorderThickness="0"
                         Foreground="White"
                         Padding="8"
                         Margin="0,5,0,0"/>

                <TextBlock Text="ms" 
                           FontSize="10" 
                           Foreground="#999999"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5,0,0,0">

                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center">

                    <TextBlock Text="Scans Number" 
                               FontSize="11" 
                               Foreground="#999999"/>

                    <Border Margin="6,0,0,0" 
                            Width="14" 
                            Height="14" 
                            CornerRadius="7" 
                            Background="#444444" 
                            Cursor="Help"
                            VerticalAlignment="Center"
                            ToolTipService.InitialShowDelay="100">

                        <TextBlock Text="?" 
                                   FontSize="10" 
                                   FontWeight="Bold"
                                   Foreground="#AAAAAA" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,1"/>

                        <Border.ToolTip>

                            <ToolTip Background="#252526" 
                                     Foreground="White" 
                                     BorderBrush="#454545"
                                     Padding="10"
                                     HasDropShadow="True">

                                <StackPanel Width="200">

                                    <TextBlock Text="Scans to Average (ScansNum)" 
                                       FontWeight="Bold" 
                                       Foreground="White" 
                                       Margin="0,0,0,5"/>

                                    <Image Source="pack://application:,,,/Common/Images/splash.png"
                                           Height="108"
                                           Width="192"
                                           Stretch="Uniform" 
                                           Margin="0,5"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                    <TextBlock Text="The number of individual spectra to be acquired and averaged by the device hardware before sending the data to the application." 
                                       Foreground="#CCCCCC" 
                                       FontSize="11" 
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                                    <TextBlock Text="• Higher values: Significantly reduces signal noise (better SNR) but increases the total cycle time." 
                                       Foreground="#AAAAAA" 
                                       FontSize="10" 
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,3"/>

                                    <TextBlock Text="• Lower values: Provides faster updates for high-speed process monitoring." 
                                       Foreground="#AAAAAA" 
                                       FontSize="10" 
                                       TextWrapping="Wrap"/>
                                </StackPanel>

                            </ToolTip>

                        </Border.ToolTip>

                    </Border>
                </StackPanel>

                <TextBox Text="{Binding ScansNum}" 
                         Background="#3E3E40"
                         BorderThickness="0"
                         Foreground="White"
                         Padding="8"
                         Margin="0,5,0,0"/>

                <TextBlock Text="ms" 
                           FontSize="10" 
                           Foreground="#999999"
                           Margin="0,2,0,0"/>
                
            </StackPanel>
            
        </Grid>
        
        <StackPanel Grid.Row="1"
                    Margin="0,5,0,0">
            
            <Button Content="Apply" 
                    Width="320"
                    Height="35"
                    Foreground="White"
                    Background="#222120"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding ApplySpecParamsCommand}"/>
            
        </StackPanel>
    </Grid>
</UserControl>
